---
// Carrusel infinito de platos
const whatsappNumber = "59178555886";

// Array con todas las imágenes de platos
const platosImages = [
  "/img/platos/1.webp",
  "/img/platos/2.webp",
  "/img/platos/3.webp",
  "/img/platos/4.webp",
  "/img/platos/5.webp",
  "/img/platos/6.webp",
  "/img/platos/7.webp",
  "/img/platos/8.webp",
  "/img/platos/9.webp",
  "/img/platos/10.webp",
  "/img/platos/11.webp",
  "/img/platos/12.webp",
  "/img/platos/13.webp",
];

// Duplicamos el array para crear el efecto infinito
const allImages = [...platosImages, ...platosImages];
---

<section id="menu" class="py-16 sm:py-20 lg:py-24 overflow-hidden" style='background-image: linear-gradient(135deg, rgba(244, 244, 244,0.07) 0%, rgba(244, 244, 244,0.07) 12.5%,rgba(211, 211, 211,0.07) 12.5%, rgba(211, 211, 211,0.07) 25%,rgba(178, 178, 178,0.07) 25%, rgba(178, 178, 178,0.07) 37.5%,rgba(145, 145, 145,0.07) 37.5%, rgba(145, 145, 145,0.07) 50%,rgba(113, 113, 113,0.07) 50%, rgba(113, 113, 113,0.07) 62.5%,rgba(80, 80, 80,0.07) 62.5%, rgba(80, 80, 80,0.07) 75%,rgba(47, 47, 47,0.07) 75%, rgba(47, 47, 47,0.07) 87.5%,rgba(14, 14, 14,0.07) 87.5%, rgba(14, 14, 14,0.07) 100%),linear-gradient(45deg, rgba(236, 236, 236,0.07) 0%, rgba(236, 236, 236,0.07) 12.5%,rgba(210, 210, 210,0.07) 12.5%, rgba(210, 210, 210,0.07) 25%,rgba(183, 183, 183,0.07) 25%, rgba(183, 183, 183,0.07) 37.5%,rgba(157, 157, 157,0.07) 37.5%, rgba(157, 157, 157,0.07) 50%,rgba(130, 130, 130,0.07) 50%, rgba(130, 130, 130,0.07) 62.5%,rgba(104, 104, 104,0.07) 62.5%, rgba(104, 104, 104,0.07) 75%,rgba(77, 77, 77,0.07) 75%, rgba(77, 77, 77,0.07) 87.5%,rgba(51, 51, 51,0.07) 87.5%, rgba(51, 51, 51,0.07) 100%),linear-gradient(90deg, #ffffff,#ffffff);'>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header de la sección -->
     <br>
    <div class="text-center mb-12 sm:mb-16" data-aos="fade-up">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1a1a1a] mb-4">
         <span class="bg-gradient-to-r from-[#9e2a2b] to-[#d4af37] bg-clip-text text-transparent">Nuestros Platos Premium</span>
      </h2>
      <br>
    </div>
  </div> <!-- Cierre de max-w-7xl para el header -->

  <!-- Carrusel Infinito (Fuera del contenedor para ser full-width) -->
  <div class="relative w-full" data-aos="fade-in" data-aos-delay="200">
    <!-- Gradientes de fade en los bordes -->
    <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-white/20 to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-white/20 to-transparent z-10 pointer-events-none"></div>
    
    <!-- Contenedor del carrusel -->
    <div class="carousel-container overflow-hidden py-8">
      <div class="carousel-track flex gap-4" style="animation: scroll-right 120s linear infinite;">
        {allImages.map((image, index) => (
          <div class="carousel-item flex-shrink-0">
            <div class="relative group">
              <div class="w-80 h-80 rounded-3xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105">
                <img
                  src={image}
                  alt={`Plato ${(index % platosImages.length) + 1}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
                <!-- Overlay con gradiente -->
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
<br>

<style>
  @keyframes scroll-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  @keyframes scroll-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .carousel-track {
    width: max-content;
  }

  /* Pausar animación al hover */
  .carousel-container:hover .carousel-track {
    animation-play-state: paused;
  }
</style>
