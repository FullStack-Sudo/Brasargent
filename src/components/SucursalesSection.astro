            name: "MILANESA DE TERNERA BRASARGENT",
            price: "110",
            desc: "(Al horno, libre de aceites) Lomito, salsa de tomate, queso mozzarella, queso catupiry, microgreens, pisca de pesto y tomates deshidratados.",
          },
          {
            name: "MILANESA DE TERNERA NAPOLITANA",
            price: "75",
            desc: "(Al horno, libre de aceites) Milanesa de lomito, jamón ahumado, salsa de tomate, queso mozzarella, microgreens.",
          },
        ],
        NOTAS:
          "TODOS LOS CORTES INCLUYEN BAR DE ENSALADAS Y 2 GUARNICIONES CALIENTES. AL COMPARTIR UN PLATO, TIENE UN COSTO ADICIONAL DE BS. 50 POR SALAD BAR.",
      },
      Rodizio: {
        "EL RODIZIO": [
          { name: "BUFFET DE ENSALADAS", price: "Incluido" },
          { name: "GUARNICIONES CALIENTES", price: "Incluido" },
          { name: "CORTES A LA ESPADA", price: "Incluido" },
          { name: "RODIZIO TRADICIONAL", price: "80" },
        ],
        NOTAS: "Precio por persona. No incluye bebidas ni postres.",
      },
    };

    const renderMenu = (sucursalName: string) => {
      const menu = MENUS[sucursalName] || MENUS["Churrasqueria"];
      if (!menuItemsContainer || !menuNav) return;

      // Renderizar Navegación
      let navHtml = "";
      let isFirst = true;
      for (const sectionTitle of Object.keys(menu)) {
        if (sectionTitle === "NOTAS") continue;
        const sectionId = sectionTitle.toLowerCase().replace(/\s+/g, "-");
        navHtml += `
          <button
            data-section="${sectionId}"
            class="menu-nav-btn group relative px-4 md:px-8 py-5 text-xs md:text-base font-black transition-all duration-300 flex-shrink-0 focus:outline-none tracking-[0.1em] md:tracking-[0.15em] uppercase ${isFirst ? "text-[#9e2a2b] border-b-4 border-[#9e2a2b]" : "text-gray-400 border-b-4 border-transparent hover:text-[#9e2a2b]"}"
            role="tab"
          >
            ${sectionTitle}
            <span
              class="absolute inset-x-0 bottom-[-4px] h-1 bg-[#9e2a2b] transform ${isFirst ? "scale-x-100" : "scale-x-0"} group-hover:scale-x-100 transition-transform duration-300"
            ></span>
          </button>
        `;
        isFirst = false;
      }
      menuNav.innerHTML = navHtml;

      // Re-vincular eventos de navegación
      const newNavButtons = menuNav.querySelectorAll(".menu-nav-btn");
      newNavButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const sectionId = button.getAttribute("data-section");
          if (!sectionId || !menuContent) return;
          const section = document.getElementById(sectionId);
          if (section) {
            const offsetTop = section.offsetTop - menuContent.offsetTop - 20;
            menuContent.scrollTo({ top: offsetTop, behavior: "smooth" });
          }
        });
      });

      // Renderizar Contenido
      let html = '<div class="space-y-16">';

      for (const [sectionTitle, items] of Object.entries(menu)) {
        if (sectionTitle === "NOTAS" || typeof items === "string") continue;

        const sectionId = sectionTitle.toLowerCase().replace(/\s+/g, "-");
        html += `
          <div id="${sectionId}" class="menu-section scroll-mt-32">
            <h4 class="text-3xl font-black text-[#9e2a2b] mb-10 pb-4 border-b-2 border-[#9e2a2b]/20 tracking-tight flex items-center gap-4">
              <span class="w-2 h-8 bg-[#9e2a2b] rounded-full"></span>
              ${sectionTitle}
            </h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-6">
              ${(items as MenuItem[])
                .map(
                  (item) => `
                <div class="group/item py-2 border-b border-gray-100 hover:bg-gray-50 transition-all duration-300 p-3 rounded-xl">
                  <div class="flex justify-between items-start gap-4">
                    <div class="flex-1">
                      <span class="text-gray-900 font-bold tracking-wide uppercase text-base block mb-1">
                        ${item.name}
                      </span>
                      ${item.desc ? `<p class="text-gray-500 text-sm font-medium leading-relaxed">${item.desc}</p>` : ""}
                    </div>
                    ${item.price ? `<span class="text-[#9e2a2b] font-black text-xl whitespace-nowrap">Bs.${item.price}</span>` : ""}
                  </div>
                </div>
              `,
                )
                .join("")}
            </div>
          </div>
        `;
      }

      if (menu.NOTAS) {
        html += `
          <div class="mt-20 mb-8 p-8 bg-gray-50 rounded-[32px] border border-gray-100 shadow-inner">
            <div class="flex items-start gap-4">
              <svg class="w-8 h-8 text-[#9e2a2b] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="text-base text-gray-600 font-bold leading-relaxed italic uppercase tracking-wider">
                ${menu.NOTAS}
              </p>
            </div>
          </div>
          <div class="h-12"></div>
        `;
      }

      html += "</div>";
      menuItemsContainer.innerHTML = html;

      // Re-vincular el observer después de renderizar
      const sections = document.querySelectorAll(".menu-section");
      sections.forEach((section) => observer.observe(section));
    };

    const updateActiveButton = (sectionId: string) => {
      const currentNavButtons = document.querySelectorAll(".menu-nav-btn");
      currentNavButtons.forEach((btn) => {
        const isActive = btn.getAttribute("data-section") === sectionId;
        const line = btn.querySelector("span");
        if (isActive) {
          btn.classList.add("text-[#9e2a2b]", "border-[#9e2a2b]");
          btn.classList.remove("text-gray-400", "border-transparent");
          if (line) line.classList.add("scale-x-100");
          if (line) line.classList.remove("scale-x-0");
        } else {
          btn.classList.remove("text-[#9e2a2b]", "border-[#9e2a2b]");
          btn.classList.add("text-gray-400", "border-transparent");
          if (line) line.classList.remove("scale-x-100");
          if (line) line.classList.add("scale-x-0");
        }
      });
    };

    const observerOptions = {
      root: menuContent,
      rootMargin: "-20% 0px -70% 0px",
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const sectionId = entry.target.getAttribute("id");
          if (sectionId) updateActiveButton(sectionId);
        }
      });
    }, observerOptions);

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const sucursalName = button.getAttribute("data-sucursal-name");
        if (modalSucursalName && sucursalName) {
          modalSucursalName.textContent = sucursalName;
          renderMenu(sucursalName);
        }
        modal?.classList.remove("hidden");
        modal?.classList.add("flex");
        document.body.style.overflow = "hidden";
        if (menuContent) menuContent.scrollTop = 0;
      });
    });

    const closeModal = () => {
      modal?.classList.add("hidden");
      modal?.classList.remove("flex");
      document.body.style.overflow = "";
    };

    closeButtons.forEach((button) =>
      button.addEventListener("click", closeModal),
    );
    modal?.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal?.classList.contains("hidden"))
        closeModal();
    });
  });
</script>

<style>
  @keyframes gradient {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .animate-gradient {
    background-size: 200% auto;
    animation: gradient 3s ease infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.2;
    }
    50% {
      opacity: 0.3;
    }
  }

  @keyframes modal-enter {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .animate-modal-enter {
    animation: modal-enter 0.3s ease-out;
  }

  /* Ocultar scrollbar en navegación */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Transición suave para botones de navegación */
  .menu-nav-btn {
    position: relative;
  }

  .menu-nav-btn::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: currentColor;
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }

  .menu-nav-btn.active::after {
    transform: scaleX(1);
  }
</style>
