---
// Componente de Testimonios con carrusel y tipografía Poppins
---

<style>
  @import url("https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap");

  .testimonials-section * {
    font-family: "Poppins", sans-serif;
  }
</style>

<section
  id="testimonios"
  class="testimonials-section py-20 px-4 sm:px-6 lg:px-8"
  style="background-image: linear-gradient(135deg, rgba(244, 244, 244,0.07) 0%, rgba(244, 244, 244,0.07) 12.5%,rgba(211, 211, 211,0.07) 12.5%, rgba(211, 211, 211,0.07) 25%,rgba(178, 178, 178,0.07) 25%, rgba(178, 178, 178,0.07) 37.5%,rgba(145, 145, 145,0.07) 37.5%, rgba(145, 145, 145,0.07) 50%,rgba(113, 113, 113,0.07) 50%, rgba(113, 113, 113,0.07) 62.5%,rgba(80, 80, 80,0.07) 62.5%, rgba(80, 80, 80,0.07) 75%,rgba(47, 47, 47,0.07) 75%, rgba(47, 47, 47,0.07) 87.5%,rgba(14, 14, 14,0.07) 87.5%, rgba(14, 14, 14,0.07) 100%),linear-gradient(45deg, rgba(236, 236, 236,0.07) 0%, rgba(236, 236, 236,0.07) 12.5%,rgba(210, 210, 210,0.07) 12.5%, rgba(210, 210, 210,0.07) 25%,rgba(183, 183, 183,0.07) 25%, rgba(183, 183, 183,0.07) 37.5%,rgba(157, 157, 157,0.07) 37.5%, rgba(157, 157, 157,0.07) 50%,rgba(130, 130, 130,0.07) 50%, rgba(130, 130, 130,0.07) 62.5%,rgba(104, 104, 104,0.07) 62.5%, rgba(104, 104, 104,0.07) 75%,rgba(77, 77, 77,0.07) 75%, rgba(77, 77, 77,0.07) 87.5%,rgba(51, 51, 51,0.07) 87.5%, rgba(51, 51, 51,0.07) 100%),linear-gradient(90deg, #ffffff,#ffffff);"
>
  <div class="text-center mb-12 sm:mb-16" data-aos="fade-up">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-[#1a1a1a] mb-4">
      <span
        class="bg-gradient-to-r from-[#9e2a2b] to-[#d4af37] bg-clip-text text-transparent"
        >Nuestros Clientes</span
      >
    </h2>
    <br />
  </div>

  <div class="hidden md:flex justify-end gap-2 mt-4">
    <button
      id="prev-btn"
      class="h-10 w-10 rounded-lg bg-neutral-100 border border-neutral-200 flex items-center justify-center cursor-pointer hover:bg-neutral-200 transition-all text-neutral-500"
      aria-label="Previous"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg
      >
    </button>
    <button
      id="next-btn"
      class="h-10 w-10 rounded-lg bg-neutral-100 border border-neutral-200 flex items-center justify-center cursor-pointer hover:bg-neutral-200 transition-all text-neutral-500"
      aria-label="Next"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
      >
    </button>
  </div>

  <div
    id="testimonials"
    class="mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 px-8 md:px-0 mt-12 md:mt-6"
  >
  </div>

  <div
    id="dots"
    class="hidden max-md:flex items-center justify-center mt-5 gap-2"
  >
  </div>
</section>

<script>
  const testimonials = [
    {
      id: 1,
      date: "Enero 2026",
      text: "La mejor experiencia👌",
      name: "Ruth Niva Loza Mendoza",
      role: "Facebook",
      img: "/img/logo/logo.jpg",
    },
    {
      id: 2,
      date: "Enero 2026",
      text: "Mi restaurante favorito de toda la vida!!! Ahora que vivo en otro país, voy sin falta el día que llego 😁. La mejor comida y la mejor atención de nuestro amigo de siempre Juvenal y todo el equipo.",
      name: "Monina Montes",
      role: "Facebook",
      img: "/img/logo/logo.jpg",
    },
    {
      id: 3,
      date: "Enero 2026",
      text: "Execelente servicio y la carne la mejor",
      name: "KariNoe LFer",
      role: "Facebook",
      img: "/img/logo/logo.jpg",
    },
    {
      id: 4,
      date: "Enero 2026",
      text: "Muchas felicidades querida Ruthy y a todo su equipo! Por estos años que no son pocos! Bendiciones y siga adelante!🥰🥂🍾",
      name: "Negra Zambrana",
      role: "Facebook",
      img: "/img/logo/logo.jpg",
    },
    {
      id: 5,
      date: "Enero 2026",
      text: "Sin duda alguna, el mejor 👌 Bendiciones y muchos éxitos más 🙌🙌🙌",
      name: "Golding Cespedes Barbery",
      role: "Facebook",
      img: "/img/logo/logo.jpg",
    },
  ];

  let index = 0,
    mobile = window.innerWidth < 768,
    timer;

  const render = () => {
    const container = document.getElementById("testimonials");
    const dotsContainer = document.getElementById("dots");
    if (!container || !dotsContainer) return;

    const count = mobile ? 1 : 3;
    const visibleTestimonials = testimonials.slice(index, index + count);

    container.innerHTML = visibleTestimonials
      .map(
        (t) => `
            <div class="group relative bg-white/80 backdrop-blur-xl hover:bg-white/95 transition-all duration-500 border border-white/40 rounded-[2.5rem] p-12 md:p-16 shadow-2xl shadow-gray-200/50 hover:shadow-gray-300/60 hover:-translate-y-2 overflow-hidden flex flex-col items-center text-center m-4 mb-16">
                <div class="absolute top-10 left-0 w-32 h-32 bg-gradient-to-br from-white/60 to-transparent -translate-x-12 -translate-y-12 rounded-full blur-2xl group-hover:from-white/80 transition-all duration-500"></div>
                
                <div class="relative space-y-8 w-full flex flex-col items-center">
                    <div class="flex flex-col items-center gap-4 w-full">
                        <div class="flex gap-1 justify-center">
                            ${'<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#d4af37" class="drop-shadow-[0_0_8px_rgba(212,175,55,0.4)]"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>'.repeat(5)}
                        </div>
                        <span class="text-[11px] font-bold text-gray-400 bg-gray-100/80 px-4 py-1.5 rounded-full uppercase tracking-widest">${t.date}</span>
                    </div>
                    
                    <div class="relative w-full px-4">
                        <span class="absolute -top-6 left-1/2 -translate-x-1/2 text-7xl text-gray-200/40 font-serif leading-none italic select-none">“</span>
                        <p class="text-base md:text-lg leading-relaxed text-gray-700 font-medium italic relative z-10">
                            ${t.text}
                        </p>
                    </div>
                    
                    <div class="pt-8 border-t border-gray-100/50 w-full flex flex-col items-center gap-5">
                        <div class="relative">
                            <div class="absolute inset-0 bg-gradient-to-tr from-[#9e2a2b] to-[#d4af37] rounded-full blur-md opacity-20 group-hover:opacity-40 transition-opacity"></div>
                            <img src="${t.img}" alt="${t.name}" class="relative w-20 h-20 rounded-full object-cover border-4 border-white shadow-xl">
                        </div>
                        <div class="flex flex-col items-center">
                            <p class="text-xl text-gray-900 font-black tracking-tight mb-2">${t.name}</p>
                            <div class="flex flex-wrap items-center justify-center gap-3">
                                <span class="bg-[#1877F2] text-white text-[11px] font-black px-3 py-1 rounded-md uppercase tracking-wider shadow-lg shadow-blue-500/20">${t.role}</span>
                                <span class="flex items-center gap-1.5 text-[11px] text-gray-500 font-bold uppercase tracking-widest bg-gray-50 px-3 py-1 rounded-md border border-gray-100">
                                    <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                                    </svg>
                                    Verificado
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        `,
      )
      .join("");

    dotsContainer.innerHTML = testimonials
      .map(
        (_, i) =>
          `<button class="w-3 h-3 rounded-full transition ${i === index ? "bg-neutral-800" : "bg-neutral-300"}" data-index="${i}" aria-label="Slide ${i + 1}"></button>`,
      )
      .join("");

    // Re-attach listeners to dots
    dotsContainer.querySelectorAll("button").forEach((btn) => {
      btn.onclick = (e) => {
        index = parseInt(e.target.dataset.index);
        render();
      };
    });
  };

  const prevBtn = document.getElementById("prev-btn");
  const nextBtn = document.getElementById("next-btn");

  if (prevBtn)
    prevBtn.onclick = () => {
      index = index - 3 < 0 ? Math.max(testimonials.length - 3, 0) : index - 3;
      render();
    };
  if (nextBtn)
    nextBtn.onclick = () => {
      index = index + 3 >= testimonials.length ? 0 : index + 3;
      render();
    };

  window.addEventListener("resize", () => {
    const wasMobile = mobile;
    mobile = window.innerWidth < 768;
    if (mobile !== wasMobile) {
      clearInterval(timer);
      if (mobile) {
        timer = setInterval(() => {
          index = (index + 1) % testimonials.length;
          render();
        }, 3000);
      }
      render();
    }
  });

  if (mobile) {
    timer = setInterval(() => {
      index = (index + 1) % testimonials.length;
      render();
    }, 3000);
  }
  render();
</script>
