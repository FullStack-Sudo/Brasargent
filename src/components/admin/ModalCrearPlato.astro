---
---
<div class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300" id="modalCrearPlato">
    <div class="modal-container bg-[#fffaf0] rounded-3xl w-full max-w-[820px] max-h-[90vh] overflow-y-auto shadow-[0_25px_60px_rgba(0,0,0,0.5)] transform scale-95 transition-all duration-400 relative">
        
        <!-- Header -->
        <div class="modal-header px-8 py-6 border-b border-gray-900/5 flex items-start justify-between sticky top-0 bg-[#fffaf0] rounded-t-3xl z-10">
            <div class="modal-title flex items-center gap-4">
                <span class="icon text-4xl">🍽️</span>
                <div>
                    <h2 class="font-serif text-2xl font-bold text-[#1a1a1a] m-0">Añadir Nuevo Plato al Menú</h2>
                    <p class="text-[#1a1a1a]/50 text-sm mt-1">Completa los datos del nuevo plato para agregarlo al menú de la sucursal</p>
                </div>
            </div>
            <button class="modal-close bg-transparent border-none w-10 h-10 rounded-xl flex items-center justify-center cursor-pointer transition-all duration-300 text-[#1a1a1a] hover:bg-[#1a1a1a]/5 hover:rotate-90" id="btnCerrarModalCrear">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        
        <!-- Body -->
        <form id="formCrearPlato" class="modal-body px-8 py-6">
            <input type="hidden" name="sucursal_id" id="create_sucursal_id" />
            
            <!-- Sección: Imagen -->
            <div class="form-section mb-8">
                <h3 class="text-base font-semibold text-[#1a1a1a] mb-4">📷 Imagen del Plato</h3>
                <div class="upload-area border-2 border-dashed border-[#1a1a1a]/15 rounded-2xl p-10 text-center cursor-pointer transition-all duration-300 bg-[#fffaf0]/30 min-h-[180px] flex items-center justify-center hover:border-[#9e2a2b] hover:bg-[#9e2a2b]/5" id="dropZone">
                    <div class="upload-content" id="uploadContent">
                        <span class="upload-icon text-5xl block mb-2">📷</span>
                        <p class="text-[#1a1a1a] font-medium m-0 mb-1">Arrastra una imagen aquí o haz clic para seleccionar</p>
                        <span class="upload-hint text-[#1a1a1a]/40 text-sm">JPG, PNG, WEBP • Max 2MB</span>
                    </div>
                    <input type="file" id="imagenInput" name="imagen" accept="image/*" class="hidden" />
                    <div id="previewContainer" class="hidden relative inline-block">
                        <img id="previewImage" src="" alt="Vista previa" class="max-h-[200px] rounded-xl object-cover shadow-md" />
                        <button type="button" id="removeImage" class="absolute -top-3 -right-3 w-8 h-8 rounded-full bg-red-500 text-white flex items-center justify-center hover:scale-110 transition-transform shadow-lg">✕</button>
                    </div>
                </div>
            </div>
            
            <!-- Sección: Información -->
            <div class="form-section mb-8">
                <h3 class="text-base font-semibold text-[#1a1a1a] mb-4">📝 Información del Plato</h3>
                
                <div class="form-row grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
                    <div class="form-group">
                        <label for="create_nombre" class="block font-medium text-[#1a1a1a] text-sm mb-1.5">Nombre del Plato <span class="text-[#9e2a2b]">*</span></label>
                        <input type="text" id="create_nombre" name="nombre" placeholder="Ej: Picaña Premium" maxlength="100" required 
                            class="w-full p-3 border-[1.5px] border-[#1a1a1a]/10 rounded-xl text-[0.95rem] font-sans transition-all bg-white text-[#1a1a1a] focus:outline-none focus:border-[#9e2a2b] focus:ring-4 focus:ring-[#9e2a2b]/10 placeholder-[#1a1a1a]/30" />
                    </div>
                    
                    <div class="form-group">
                        <label for="create_categoria" class="block font-medium text-[#1a1a1a] text-sm mb-1.5">Categoría <span class="text-[#9e2a2b]">*</span></label>
                        <select id="create_categoria" name="categoria_id" required
                            class="w-full p-3 border-[1.5px] border-[#1a1a1a]/10 rounded-xl text-[0.95rem] font-sans transition-all bg-white text-[#1a1a1a] focus:outline-none focus:border-[#9e2a2b] focus:ring-4 focus:ring-[#9e2a2b]/10">
                            <option value="">Seleccionar categoría</option>
                            <option value="1">Cortes</option>
                            <option value="2">Parrilladas</option>
                            <option value="3">Entradas</option>
                            <option value="4">Guarniciones</option>
                            <option value="5">Cortes Premium</option>
                            <option value="6">Comida Rápida</option>
                            <option value="7">Sándwiches</option>
                            <option value="8">Ensaladas</option>
                            <option value="9">Bebidas</option>
                            <option value="10">Experiencia</option>
                            <option value="11">Espadas</option>
                            <option value="12">Buffet</option>
                            <option value="13">Postres</option>
                        </select>
                    </div>
                </div>
                
                <div class="form-group mb-5">
                    <label for="create_precio" class="block font-medium text-[#1a1a1a] text-sm mb-1.5">Precio (Bs.) <span class="text-[#9e2a2b]">*</span></label>
                    <div class="relative">
                        <input type="number" id="create_precio" name="precio" placeholder="120.00" step="0.50" min="0" required 
                            class="w-full p-3 pl-12 border-[1.5px] border-[#1a1a1a]/10 rounded-xl text-[0.95rem] font-sans transition-all bg-white text-[#1a1a1a] focus:outline-none focus:border-[#9e2a2b] focus:ring-4 focus:ring-[#9e2a2b]/10 placeholder-[#1a1a1a]/30" />
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-[#1a1a1a]/40 font-medium">Bs.</span>
                    </div>
                    <span class="block text-[#1a1a1a]/40 text-xs mt-1.5">Ej: 120.00</span>
                </div>
                
                <div class="form-group mb-5">
                    <label for="create_descripcion" class="block font-medium text-[#1a1a1a] text-sm mb-1.5">Descripción</label>
                    <textarea id="create_descripcion" name="descripcion" rows="4" placeholder="Breve descripción de los ingredientes o preparación..." maxlength="500"
                        class="w-full p-3 border-[1.5px] border-[#1a1a1a]/10 rounded-xl text-[0.95rem] font-sans transition-all bg-white text-[#1a1a1a] focus:outline-none focus:border-[#9e2a2b] focus:ring-4 focus:ring-[#9e2a2b]/10 placeholder-[#1a1a1a]/30 resize-none"></textarea>
                    <span class="block text-right text-[#1a1a1a]/30 text-xs mt-1.5" id="charCounter">0/500 caracteres</span>
                </div>
            </div>
            
            <!-- Sección: Opciones -->
            <div class="form-section">
                <h3 class="text-base font-semibold text-[#1a1a1a] mb-4">⚙️ Opciones Adicionales</h3>
                
                <div class="form-group checkbox-group mb-6">
                    <label class="checkbox-label flex items-start gap-3 cursor-pointer p-3 bg-[#1a1a1a]/[0.03] rounded-xl hover:bg-[#1a1a1a]/[0.06] transition-colors">
                        <input type="checkbox" name="destacado" id="create_destacado" class="peer hidden" value="1" />
                        <div class="custom-checkbox w-[22px] h-[22px] min-w-[22px] border-2 border-[#1a1a1a]/20 rounded-md flex items-center justify-center transition-all mt-0.5 peer-checked:bg-[#9e2a2b] peer-checked:border-[#9e2a2b]">
                            <svg class="w-3.5 h-3.5 text-white opacity-0 peer-checked:opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <div class="checkbox-text">
                            <strong class="block text-[#1a1a1a] font-semibold text-sm">Destacar este plato en el menú</strong>
                            <small class="text-[#1a1a1a]/50 text-xs">Aparecerá con un badge "🔥 Destacado"</small>
                        </div>
                    </label>
                </div>
                
                <div class="form-group">
                    <label class="block font-medium text-[#1a1a1a] text-sm mb-2">Sucursales disponibles <span class="text-[#9e2a2b]">*</span></label>
                    <div class="sucursales-grid grid grid-cols-1 sm:grid-cols-3 gap-3">
                        <label class="sucursal-check flex items-center gap-2.5 p-3 bg-[#1a1a1a]/[0.03] border-[1.5px] border-[#1a1a1a]/10 rounded-xl cursor-pointer transition-colors hover:bg-[#1a1a1a]/[0.06] [&:has(:checked)]:bg-[#9e2a2b]/5 [&:has(:checked)]:border-[#9e2a2b]">
                            <input type="checkbox" name="sucursales" value="1" class="hidden" checked />
                            <span class="sucursal-icon text-lg">🔥</span>
                            <span class="sucursal-name font-medium text-[#1a1a1a] text-sm">Churrasquería</span>
                        </label>
                        <label class="sucursal-check flex items-center gap-2.5 p-3 bg-[#1a1a1a]/[0.03] border-[1.5px] border-[#1a1a1a]/10 rounded-xl cursor-pointer transition-colors hover:bg-[#1a1a1a]/[0.06] [&:has(:checked)]:bg-[#9e2a2b]/5 [&:has(:checked)]:border-[#9e2a2b]">
                            <input type="checkbox" name="sucursales" value="2" class="hidden" checked />
                            <span class="sucursal-icon text-lg">⚡</span>
                            <span class="sucursal-name font-medium text-[#1a1a1a] text-sm">Fast Grill</span>
                        </label>
                        <label class="sucursal-check flex items-center gap-2.5 p-3 bg-[#1a1a1a]/[0.03] border-[1.5px] border-[#1a1a1a]/10 rounded-xl cursor-pointer transition-colors hover:bg-[#1a1a1a]/[0.06] [&:has(:checked)]:bg-[#9e2a2b]/5 [&:has(:checked)]:border-[#9e2a2b]">
                            <input type="checkbox" name="sucursales" value="3" class="hidden" checked />
                            <span class="sucursal-icon text-lg">🥩</span>
                            <span class="sucursal-name font-medium text-[#1a1a1a] text-sm">Rodizio</span>
                        </label>
                    </div>
                    <span class="block text-[#1a1a1a]/40 text-xs mt-2">Selecciona las sucursales donde estará disponible</span>
                </div>
            </div>
            <div id="formError" class="hidden mt-4 p-3 bg-red-50 text-red-600 rounded-xl border border-red-100 text-sm"></div>
        </form>
        
        <!-- Footer -->
        <div class="modal-footer px-8 py-5 border-t border-[#1a1a1a]/5 flex flex-col-reverse sm:flex-row justify-end gap-3 sticky bottom-0 bg-[#fffaf0] rounded-b-3xl">
            <button type="button" class="btn-cancel w-full sm:w-auto px-8 py-3 bg-transparent text-[#1a1a1a] border-[1.5px] border-[#1a1a1a]/10 rounded-xl font-semibold hover:bg-[#1a1a1a]/5 transition-colors" id="btnCancelarCrear">
                Cancelar
            </button>
            <button type="submit" form="formCrearPlato" class="btn-save w-full sm:w-auto px-8 py-3 bg-gradient-to-br from-[#9e2a2b] to-[#7a2021] text-[#fffaf0] rounded-xl font-semibold shadow-[0_4px_16px_rgba(158,42,43,0.3)] hover:scale-[1.02] hover:shadow-[0_8px_24px_rgba(158,42,43,0.4)] transition-all min-w-[160px] flex justify-center items-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed disabled:transform-none" id="btnGuardarCrear">
                <span class="btn-text">Guardar Plato</span>
                <svg class="btn-spinner hidden w-5 h-5 animate-spin text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            </button>
        </div>
    </div>
</div>

<style>
    .modal-active {
        opacity: 1 !important;
        pointer-events: auto !important;
    }
    .modal-active > .modal-container {
        transform: scale(1) translateY(0) !important;
        opacity: 1 !important;
    }
    .modal-overlay {
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(8px);
    }
    .form-group input.error,
    .form-group select.error {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.1) !important;
    }
</style>

<script>
    // Validaciones del frontend
    const form = document.getElementById('formCrearPlato') as HTMLFormElement;
    const desc = document.getElementById('create_descripcion') as HTMLTextAreaElement;
    const charCounter = document.getElementById('charCounter');
    
    if (desc && charCounter) {
        desc.addEventListener('input', () => {
            charCounter.textContent = `${desc.value.length}/500 caracteres`;
        });
    }

    // Lógica de Image Upload
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('imagenInput') as HTMLInputElement;
    const previewContainer = document.getElementById('previewContainer');
    const previewImage = document.getElementById('previewImage') as HTMLImageElement;
    const uploadContent = document.getElementById('uploadContent');
    const removeImageBtn = document.getElementById('removeImage');

    function handleFile(file: File) {
        if (!file || !file.type.startsWith('image/')) return;
        const reader = new FileReader();
        reader.onload = (e) => {
            if(e.target?.result && previewImage && previewContainer && uploadContent) {
                previewImage.src = e.target.result as string;
                previewContainer.classList.remove('hidden');
                uploadContent.classList.add('hidden');
            }
        };
        reader.readAsDataURL(file);
    }

    if (dropZone && fileInput) {
        dropZone.addEventListener('click', (e) => {
            if (e.target !== removeImageBtn) {
                fileInput.click();
            }
        });

        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('border-[#9e2a2b]', 'bg-[#9e2a2b]/5');
        });

        dropZone.addEventListener('dragleave', (e) => {
            e.preventDefault();
            dropZone.classList.remove('border-[#9e2a2b]', 'bg-[#9e2a2b]/5');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('border-[#9e2a2b]', 'bg-[#9e2a2b]/5');
            if (e.dataTransfer?.files.length) {
                const dt = new DataTransfer();
                dt.items.add(e.dataTransfer.files[0]);
                fileInput.files = dt.files;
                handleFile(e.dataTransfer.files[0]);
            }
        });

        fileInput.addEventListener('change', () => {
            if (fileInput.files?.length) {
                handleFile(fileInput.files[0]);
            }
        });
    }

    if (removeImageBtn) {
        removeImageBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (fileInput) fileInput.value = '';
            if (previewContainer) previewContainer.classList.add('hidden');
            if (uploadContent) uploadContent.classList.remove('hidden');
            if (previewImage) previewImage.src = '';
        });
    }
</script>
