---
---

<div id="modalEditarPlato" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="modalEditarOverlay"></div>
    
    <div class="relative bg-white rounded-2xl w-full max-w-md p-6 shadow-2xl transform scale-95 transition-transform duration-300" id="modalEditarContent">
        <div class="flex justify-between items-center mb-5">
            <h3 class="text-xl font-serif font-semibold text-gray-900">Editar Plato</h3>
            <button id="btnCerrarModalEditar" class="text-gray-400 hover:text-gray-600 transition-colors">
                ✕
            </button>
        </div>
        
        <form id="formEditarPlato" class="space-y-4">
            <input type="hidden" id="edit_plato_id" name="plato_id" />
            
            <div>
                <label for="edit_nombre" class="block text-sm font-medium text-gray-700 mb-1">Nombre del Plato</label>
                <input 
                    type="text" 
                    id="edit_nombre" 
                    name="nombre" 
                    class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 text-sm focus:ring-2 focus:ring-[#9e2a2b] focus:border-[#9e2a2b] outline-none transition-all"
                    required 
                    maxlength="100"
                />
            </div>
            
            <div>
                <label for="edit_descripcion" class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
                <textarea 
                    id="edit_descripcion" 
                    name="descripcion" 
                    rows="3" 
                    class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 text-sm focus:ring-2 focus:ring-[#9e2a2b] focus:border-[#9e2a2b] outline-none transition-all resize-none"
                ></textarea>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label for="edit_precio" class="block text-sm font-medium text-gray-700 mb-1">Precio (Bs.)</label>
                    <input 
                        type="number" 
                        id="edit_precio" 
                        name="precio" 
                        step="0.50" 
                        min="0"
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 text-sm focus:ring-2 focus:ring-[#9e2a2b] focus:border-[#9e2a2b] outline-none transition-all"
                        required
                    />
                </div>
                <div>
                    <label for="edit_categoria" class="block text-sm font-medium text-gray-700 mb-1">Categoría</label>
                    <!-- Las categorías podrían venir de BD, hardcoded para demostración -->
                    <select 
                        id="edit_categoria" 
                        name="categoria_id"
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 text-sm focus:ring-2 focus:ring-[#9e2a2b] focus:border-[#9e2a2b] outline-none transition-all"
                    >
                        <option value="1">Rodizio</option>
                        <option value="2">Fast Grill</option>
                        <option value="3">A la Carta</option>
                        <option value="4">Bebidas</option>
                        <option value="5">Entradas</option>
                    </select>
                </div>
            </div>
            
            <div class="pt-4 flex gap-3">
                <button type="button" id="btnCancelarEditar" class="flex-1 px-4 py-2 border border-gray-200 text-gray-600 rounded-xl text-sm font-medium hover:bg-gray-50 transition-colors">
                    Cancelar
                </button>
                <button type="submit" id="btnGuardarEditar" class="flex-1 px-4 py-2 bg-[#9e2a2b] text-white rounded-xl text-sm font-medium hover:bg-[#8a2426] transition-colors relative">
                    <span class="btn-text">Guardar Cambios</span>
                    <span class="loader hidden absolute inset-0 flex items-center justify-center">
                        <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                    </span>
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .modal-active {
        opacity: 1 !important;
        pointer-events: auto !important;
    }
    .modal-active #modalEditarContent {
        transform: scale(1) !important;
    }
</style>
