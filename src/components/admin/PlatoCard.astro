---
interface Props {
    plato: {
        id: number;
        nombre: string;
        descripcion: string;
        precio: number;
        categoria: string;
        imagen_url: string;
        disponible: number | boolean;
        destacado: number | boolean;
    };
    sucursalId: number;
}

const { plato, sucursalId } = Astro.props;
const isAvailable = Boolean(plato.disponible);

// Fallback logo based on sucursal ID
const fallbackLogos: Record<number, string> = {
    1: "/img/logo/LOGO1SF.png", // Churrasquería
    2: "/img/logo/LOGO2SF.png", // Fast Grill
    3: "/img/logo/LOGO3SF.png", // Rodizio
};
const defaultImage = fallbackLogos[sucursalId] || "/img/logo/logo-SF.png";
const hasImage = Boolean(plato.imagen_url && plato.imagen_url.trim() !== '');
const imageUrl = hasImage ? plato.imagen_url : defaultImage;
---

<div class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md overflow-hidden flex flex-col h-full plato-card group transition-all" data-id={plato.id}>
    <!-- Imagen del plato -->
    <div class="relative h-44 bg-gray-50 overflow-hidden flex items-center justify-center p-2">
        <img 
            src={imageUrl} 
            alt={plato.nombre}
            class={`w-full h-full transition-transform duration-700 group-hover:scale-110 ${hasImage ? 'object-cover' : 'object-contain opacity-50'}`}
            onerror={`this.src='${defaultImage}'; this.className='w-full h-full object-contain opacity-50 transition-transform duration-700 group-hover:scale-110';`}
        />
        
        <!-- Botón para subir imagen (Hover) -->
        <button class="absolute inset-0 bg-black/50 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity btn-upload-img backdrop-blur-[2px]" data-id={plato.id}>
            <div class="bg-white/90 text-gray-900 rounded-full w-12 h-12 flex items-center justify-center mb-2 shadow-lg transform group-hover:scale-110 transition-transform duration-300">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <span class="text-white text-sm font-medium drop-shadow-md">Cambiar Imagen</span>
        </button>
    </div>

    <!-- Info del plato -->
    <div class="p-5 flex flex-col flex-1">
        <div class="flex justify-between items-start mb-1">
            <h4 class="font-serif font-bold text-gray-900 text-lg leading-tight line-clamp-2" title={plato.nombre}>
                {plato.nombre}
            </h4>
        </div>
        
        <p class="text-sm text-gray-500 mb-4 line-clamp-2 flex-1 leading-relaxed" title={plato.descripcion}>
            {plato.descripcion || "Sin descripción"}
        </p>
        
        <div class="flex items-center gap-2 mb-4">
            <span class={`status-badge inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold shadow-sm transition-colors border ${
                isAvailable ? 'bg-[#10b981]/10 text-[#10b981] border-[#10b981]/20' : 'bg-[#ef4444]/10 text-[#ef4444] border-[#ef4444]/20'
            }`}>
                {isAvailable ? '✅ Disponible' : '❌ Agotado'}
            </span>
        </div>

        <div class="flex justify-between items-center mt-auto pt-4 border-t border-gray-100">
            <div class="flex flex-col">
                <span class="text-[10px] text-gray-400 uppercase font-bold tracking-wider mb-0.5">Precio</span>
                <span class="font-bold text-gray-900 text-lg">Bs. {Number(plato.precio).toFixed(2)}</span>
            </div>
            
            <div class="flex gap-2">
                <!-- Toggle Disponibilidad -->
                <button 
                    class={`btn-toggle-status p-2.5 rounded-xl transition-all shadow-sm border ${
                        isAvailable 
                        ? 'bg-white border-gray-200 text-gray-400 hover:text-[#ef4444] hover:bg-[#ef4444]/5 hover:border-[#ef4444]/30' 
                        : 'bg-white border-gray-200 text-gray-400 hover:text-[#10b981] hover:bg-[#10b981]/5 hover:border-[#10b981]/30'
                    }`}
                    data-id={plato.id}
                    data-sucursal={sucursalId}
                    data-status={isAvailable ? '1' : '0'}
                    title={isAvailable ? "Marcar como Agotado" : "Marcar como Disponible"}
                >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                    </svg>
                </button>
                
                <!-- Botón Editar -->
                <button 
                    class="btn-edit-plato p-2.5 bg-gray-50 border border-gray-200 text-gray-600 rounded-xl hover:bg-gray-900 hover:text-white hover:border-gray-900 transition-all shadow-sm group-hover:bg-gray-900 group-hover:text-white group-hover:border-gray-900"
                    data-id={plato.id}
                    data-nombre={plato.nombre}
                    data-descripcion={plato.descripcion}
                    data-precio={plato.precio}
                    data-categoria={plato.categoria}
                    title="Editar información"
                >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                </button>
            </div>
        </div>
    </div>
</div>
