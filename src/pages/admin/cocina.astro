</style>

<script is:inline define:vars={{ userSucursal }}>
// ============================================
// VARIABLES GLOBALES PARA NUEVO PEDIDO
// ============================================
let pedidoActual = [];

// ============================================
// FUNCIONES DE LA COCINA
// ============================================
window.cambiarTab = function(tab) {
    const panels = {
        'pendientes': document.getElementById('panel-pendientes'),
        'listos': document.getElementById('panel-listos'),
        'entregados': document.getElementById('panel-entregados')
    };
    
    const tabs = document.querySelectorAll('.cocina-tabs button');
    
    Object.keys(panels).forEach(key => {
        if (panels[key]) {
            panels[key].style.display = key === tab ? 'block' : 'none';
        }
    });
    
    tabs.forEach(btn => {
        btn.classList.remove('tab-active');
        if (btn.textContent.includes(tab === 'pendientes' ? 'Pendientes' :
                                   tab === 'listos' ? 'Listos' : 'Historial')) {
            btn.classList.add('tab-active');
        }
    });
}

// ============================================
// CAMBIAR ESTADO DE GRUPO (Cocinero)
// ============================================
window.cambiarEstadoGrupo = async function(grupoId, nuevoEstado) {
    if (!confirm(`¿Cambiar estado del pedido a "${nuevoEstado}"?`)) return;
    
    try {
        const response = await fetch(`/api/cocina/grupo/${grupoId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ estado: nuevoEstado })
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert('✅ Estado actualizado');
            location.reload();
        } else {
            alert('❌ Error: ' + result.error);
        }
    } catch (error) {
        alert('❌ Error de conexión');
    }
}

// ============================================
// ENTREGAR PEDIDO GRUPO (Mesero)
// ============================================
window.entregarPedidoGrupo = async function(grupoId) {
    if (!confirm('¿Entregar este pedido al cliente?')) return;
    
    try {
        const response = await fetch(`/api/cocina/grupo/${grupoId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ estado: 'entregado' })
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert('✅ Pedido entregado al cliente');
            location.reload();
        } else {
            alert('❌ Error: ' + result.error);
        }
    } catch (error) {
        alert('❌ Error de conexión');
    }
}

// ============================================
// ABRIR MODAL DE NUEVO PEDIDO
// ============================================
window.abrirModalPedido = function() {
    pedidoActual = [];
    document.getElementById('modalNuevoPedido').style.display = 'flex';
    document.body.style.overflow = 'hidden';
    actualizarResumen();
    
    document.getElementById('mesaPedido').value = '';
    document.getElementById('nombreCliente').value = '';
    document.getElementById('platoPedido').value = '';
    document.getElementById('cantidadPedido').value = '1';
    document.getElementById('notasPedido').value = '';
    
    filtrarPorCategoria('todos');
}

window.cerrarModalPedido = function(event) {
    if (event && event.target !== event.currentTarget) return;
    const modal = document.getElementById('modalNuevoPedido');
    modal.style.display = 'none';
    document.body.style.overflow = '';
}

// ============================================
// FILTRAR POR CATEGORÍA
// ============================================
window.filtrarPorCategoria = function(categoria) {
    const select = document.getElementById('platoPedido');
    const options = select.querySelectorAll('option');
    
    document.querySelectorAll('.btn-categoria').forEach(btn => {
        btn.classList.remove('active');
        if (btn.textContent.trim() === categoria || 
            (categoria === 'todos' && btn.textContent.trim() === '📋 Todos')) {
            btn.classList.add('active');
        }
    });
    
    options.forEach(option => {
        if (option.value === '') return;
        const texto = option.textContent;
        if (categoria === 'todos' || texto.includes(categoria)) {
            option.style.display = '';
        } else {
            option.style.display = 'none';
        }
    });
}

// ============================================
// AGREGAR PLATO AL PEDIDO
// ============================================
window.agregarPlatoPedido = function() {
    const platoSelect = document.getElementById('platoPedido');
    const cantidad = parseInt(document.getElementById('cantidadPedido').value) || 1;
    const platoId = parseInt(platoSelect.value);
    
    if (!platoId) {
        alert('❌ Por favor selecciona un plato');
        return;
    }
    
    const platoNombre = platoSelect.options[platoSelect.selectedIndex].text;
    const precioMatch = platoNombre.match(/Bs\.\s*([\d.]+)/);
    const precio = precioMatch ? parseFloat(precioMatch[1]) : 0;
    const nombreLimpio = platoNombre.replace(/\s*-\s*Bs\..*$/, '').trim();
    
    const existente = pedidoActual.find(p => p.id === platoId);
    if (existente) {
        existente.cantidad += cantidad;
    } else {
        pedidoActual.push({
            id: platoId,
            nombre: nombreLimpio,
            cantidad: cantidad,
            precio: precio
        });
    }
    
    actualizarResumen();
    document.getElementById('platoPedido').value = '';
    document.getElementById('cantidadPedido').value = '1';
}

window.eliminarPlatoPedido = function(index) {
    pedidoActual.splice(index, 1);
    actualizarResumen();
}

window.actualizarResumen = function() {
    const lista = document.getElementById('listaPlatosAgregados');
    const totalElement = document.getElementById('totalPedido');
    
    if (pedidoActual.length === 0) {
        lista.innerHTML = '<p class="empty-platos">No hay platos agregados</p>';
        totalElement.textContent = 'Bs. 0.00';
        return;
    }
    
    let total = 0;
    let html = '';
    
    pedidoActual.forEach((item, index) => {
        const subtotal = item.cantidad * item.precio;
        total += subtotal;
        html += `
            <div class="item-plato">
                <div class="plato-info">
                    <span class="plato-cantidad">${item.cantidad}x</span>
                    <span class="plato-nombre">${item.nombre}</span>
                </div>
                <div>
                    <span class="plato-precio">Bs. ${subtotal.toFixed(2)}</span>
                    <button class="btn-eliminar-plato" onclick="eliminarPlatoPedido(${index})">✕</button>
                </div>
            </div>
        `;
    });
    
    lista.innerHTML = html;
    totalElement.textContent = `Bs. ${total.toFixed(2)}`;
}

// ============================================
// ENVIAR PEDIDO A COCINA (AGRUPADO)
// ============================================
window.enviarPedidoCocina = async function() {
    const mesa = document.getElementById('mesaPedido').value;
    const nombreCliente = document.getElementById('nombreCliente').value.trim();
    const notas = document.getElementById('notasPedido').value.trim();
    
    if (!mesa) {
        alert('❌ Por favor ingresa el número de mesa');
        return;
    }
    
    if (pedidoActual.length === 0) {
        alert('❌ Agrega al menos un plato al pedido');
        return;
    }
    
    if (!confirm(`¿Enviar pedido para la mesa ${mesa}${nombreCliente ? ' - ' + nombreCliente : ''} a cocina?`)) return;
    
    const btn = document.querySelector('.btn-enviar-pedido');
    btn.textContent = '⏳ Enviando...';
    btn.disabled = true;
    
    try {
        const platos = pedidoActual.map(item => ({
            plato_id: item.id,
            cantidad: item.cantidad
        }));
        
        const data = {
            sucursal_id: parseInt(userSucursal) || 1,
            mesa_id: parseInt(mesa),
            nombre_cliente: nombreCliente || `Mesa ${mesa}`,
            platos: platos,
            prioridad: 'normal',
            notas: notas || null
        };
        
        const response = await fetch('/api/cocina/pedido/crear', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert(`✅ Pedido enviado a cocina (${result.items} platos, Total: Bs. ${Number(result.total).toFixed(2)})`);
            cerrarModalPedido();
            location.reload();
        } else {
            alert('❌ Error: ' + result.error);
        }
    } catch (error) {
        alert('❌ Error al enviar pedido: ' + error.message);
    } finally {
        btn.textContent = '🚀 Enviar Pedido a Cocina';
        btn.disabled = false;
    }
}

// ============================================
// CERRAR MODAL CON ESC
// ============================================
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        cerrarModalPedido();
    }
});
</script>
