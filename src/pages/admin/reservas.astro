---
// src/pages/admin/reservas.astro
// Página completa de gestión de reservas
import AdminLayout from '../../layouts/AdminLayout.astro';
import pool from '../../lib/db';

// Obtener parámetros de filtro
const url = new URL(Astro.request.url);
const sucursalId = url.searchParams.get('sucursal') || '';
const estado = url.searchParams.get('estado') || '';
const fechaInicio = url.searchParams.get('fecha_inicio') || '';
const fechaFin = url.searchParams.get('fecha_fin') || '';

// Construir query de reservas
let sql = `
    SELECT 
        r.id,
        r.nombre_cliente,
        r.telefono,
        r.telefono_completo,
        r.codigo_pais,
        r.fecha,
        r.hora,
        r.numero_personas,
        r.estado,
        r.observaciones,
        r.created_at,
        r.fecha_confirmacion,
        r.fecha_rechazo,
        r.mensaje_admin,
        r.cubiertos_reservados,
        s.nombre AS sucursal_nombre,
        s.id AS sucursal_id,
        s.cubiertos_disponibles
    FROM reservas r
    JOIN sucursales s ON r.sucursal_id = s.id
    WHERE 1=1
`;

const params: any[] = [];

if (sucursalId) {
    sql += ` AND r.sucursal_id = ?`;
    params.push(parseInt(sucursalId));
}

if (estado) {
    sql += ` AND r.estado = ?`;
    params.push(estado);
}

if (fechaInicio) {
    sql += ` AND r.fecha >= ?`;
    params.push(fechaInicio);
}

if (fechaFin) {
    sql += ` AND r.fecha <= ?`;
    params.push(fechaFin);
}

sql += ` ORDER BY r.fecha DESC, r.hora DESC`;

const [reservasRows] = await pool.query(sql, params) as any[];
const reservas = reservasRows;

// Obtener sucursales para el filtro
const [sucursalesRows] = await pool.query(
    `SELECT id, nombre FROM sucursales WHERE activo = 1 ORDER BY nombre`
) as any[];
const sucursales = sucursalesRows;

// Estadísticas
const estadisticas = {
    total: reservas.length,
    pendientes: reservas.filter((r: any) => r.estado === 'pendiente').length,
    confirmadas: reservas.filter((r: any) => r.estado === 'confirmada').length,
    rechazadas: reservas.filter((r: any) => r.estado === 'rechazada').length,
    canceladas: reservas.filter((r: any) => r.estado === 'cancelada').length
};

// Formatear fecha
const formatearFecha = (fecha: string) => {
    return new Date(fecha).toLocaleDateString('es-ES', {
        weekday: 'short',
        year: 'numeric',
        month: 'short',
        day: 'numeric'
    });
};

// Estado badge
const estadoBadge = (estado: string) => {
    const clases = {
        'pendiente': 'badge-pendiente',
        'confirmada': 'badge-confirmada',
        'rechazada': 'badge-rechazada',
        'cancelada': 'badge-cancelada'
    };
    return clases[estado as keyof typeof clases] || 'badge-pendiente';
};

const estadoTexto = (estado: string) => {
    const textos = {
        'pendiente': '⏳ Pendiente',
        'confirmada': '✅ Confirmada',
        'rechazada': '❌ Rechazada',
        'cancelada': '⏰ Cancelada'
    };
    return textos[estado as keyof typeof textos] || estado;
};
---

<AdminLayout title="Reservas" description="Gestión completa de todas las reservas">
    <!-- Estadísticas -->
        <div class="estadisticas-grid">
            <div class="stat-card">
                <span class="stat-icon">📋</span>
                <div>
                    <span class="stat-number">{estadisticas.total}</span>
                    <span class="stat-label">Total Reservas</span>
                </div>
            </div>
            <div class="stat-card stat-pendiente">
                <span class="stat-icon">⏳</span>
                <div>
                    <span class="stat-number">{estadisticas.pendientes}</span>
                    <span class="stat-label">Pendientes</span>
                </div>
            </div>
            <div class="stat-card stat-confirmada">
                <span class="stat-icon">✅</span>
                <div>
                    <span class="stat-number">{estadisticas.confirmadas}</span>
                    <span class="stat-label">Confirmadas</span>
                </div>
            </div>
            <div class="stat-card stat-rechazada">
                <span class="stat-icon">❌</span>
                <div>
                    <span class="stat-number">{estadisticas.rechazadas}</span>
                    <span class="stat-label">Rechazadas</span>
                </div>
            </div>
        </div>
        
        <!-- Filtros -->
        <div class="filtros-container">
            <form method="GET" class="filtros-form">
                <div class="filtro-group">
                    <label>Sucursal</label>
                    <select name="sucursal">
                        <option value="">Todas</option>
                        {sucursales.map((s: any) => (
                            <option value={s.id} selected={sucursalId === String(s.id)}>
                                {s.nombre}
                            </option>
                        ))}
                    </select>
                </div>
                
                <div class="filtro-group">
                    <label>Estado</label>
                    <select name="estado">
                        <option value="">Todos</option>
                        <option value="pendiente" selected={estado === 'pendiente'}>Pendiente</option>
                        <option value="confirmada" selected={estado === 'confirmada'}>Confirmada</option>
                        <option value="rechazada" selected={estado === 'rechazada'}>Rechazada</option>
                        <option value="cancelada" selected={estado === 'cancelada'}>Cancelada</option>
                    </select>
                </div>
                
                <div class="filtro-group">
                    <label>Fecha Inicio</label>
                    <input type="date" name="fecha_inicio" value={fechaInicio} />
                </div>
                
                <div class="filtro-group">
                    <label>Fecha Fin</label>
                    <input type="date" name="fecha_fin" value={fechaFin} />
                </div>
                
                <div class="filtro-actions">
                    <button type="submit" class="btn-filtrar">🔍 Filtrar</button>
                    <a href="/admin/reservas" class="btn-limpiar">✕ Limpiar</a>
                </div>
            </form>
        </div>
        
        <!-- Tabla de Reservas -->
        <div class="section-card">
            {reservas.length === 0 ? (
                <div class="empty-state">
                    <span class="empty-icon">📭</span>
                    <p>No hay reservas</p>
                    <span class="empty-sub">Ajusta los filtros para ver más resultados</span>
                </div>
            ) : (
                <div class="table-wrapper">
                    <table class="tabla-reservas">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Teléfono</th>
                                <th>Sucursal</th>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Personas</th>
                                <th>Cubiertos</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            {reservas.map((reserva: any) => (
                                <tr class={`row-estado-${reserva.estado}`}>
                                    <td>
                                        <strong>{reserva.nombre_cliente}</strong>
                                    </td>
                                    <td>
                                        <a href={`https://wa.me/${reserva.telefono_completo || '591' + reserva.telefono}`} 
                                           target="_blank" 
                                           class="whatsapp-link">
                                            💬 {reserva.codigo_pais || '591'} {reserva.telefono}
                                        </a>
                                    </td>
                                    <td>{reserva.sucursal_nombre}</td>
                                    <td>{formatearFecha(reserva.fecha)}</td>
                                    <td>{reserva.hora}</td>
                                    <td>{reserva.numero_personas}</td>
                                    <td>{reserva.cubiertos_reservados || '-'}</td>
                                    <td>
                                        <span class={`badge ${estadoBadge(reserva.estado)}`}>
                                            {estadoTexto(reserva.estado)}
                                        </span>
                                    </td>
                                    <td>
                                        <div class="acciones-btns">
                                            {reserva.estado === 'pendiente' && (
                                                <>
                                                    <button class="btn-aprobar" 
                                                            onclick={`aprobarReserva(${reserva.id}, ${reserva.sucursal_id}, ${reserva.numero_personas}, ${reserva.cubiertos_disponibles})`}>
                                                        ✅
                                                    </button>
                                                    <button class="btn-rechazar" 
                                                            onclick={`rechazarReserva(${reserva.id})`}>
                                                        ❌
                                                    </button>
                                                </>
                                            )}
                                            <button class="btn-whatsapp" 
                                                    onclick={`enviarWhatsAppAdmin('${reserva.telefono_completo || '591' + reserva.telefono}', '${reserva.nombre_cliente}', '${reserva.sucursal_nombre}', '${reserva.fecha}', '${reserva.hora}')`}>
                                                💬
                                            </button>
                                            <button class="btn-detalle" 
                                                    onclick={`verDetalle(${reserva.id})`} title="Ver detalle">
                                                📋
                                            </button>
                                            <button class="btn-eliminar" 
                                                    onclick={`borrarReserva(${reserva.id})`} title="Eliminar reserva">
                                                🗑️
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            )}
        </div>
</AdminLayout>

<script>
// ============================================
// FUNCIONES DE ACCIÓN
// ============================================

window.aprobarReserva = async function(id, sucursalId, personas, disponibles) {
    if (personas > disponibles) {
        alert(`❌ No hay suficientes cubiertos. Disponibles: ${disponibles}`);
        return;
    }
    
    if (!confirm(`¿Aprobar reserva de ${personas} personas?`)) return;
    
    try {
        const response = await fetch(`/api/reservas/${id}/aprobar`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ accion: 'aprobar' })
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert('✅ Reserva aprobada exitosamente');
            location.reload();
        } else {
            alert('❌ Error: ' + result.error);
        }
    } catch (error) {
        alert('❌ Error de conexión');
    }
}

window.rechazarReserva = async function(id) {
    const motivo = prompt('Motivo del rechazo:', 'No hay disponibilidad');
    if (motivo === null) return;
    
    if (!confirm('¿Rechazar esta reserva?')) return;
    
    try {
        const response = await fetch(`/api/reservas/${id}/aprobar`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                accion: 'rechazar',
                mensaje: motivo
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert('❌ Reserva rechazada');
            location.reload();
        } else {
            alert('❌ Error: ' + result.error);
        }
    } catch (error) {
        alert('❌ Error de conexión');
    }
}

window.enviarWhatsAppAdmin = function(telefono, nombre, sucursal, fecha, hora) {
    let fechaObj = new Date(fecha);
    
    // Si por alguna razón viene en formato YYYY-MM-DD simple y da error por zona horaria (raro en este caso)
    if (isNaN(fechaObj.getTime())) {
        fechaObj = new Date(fecha + 'T00:00:00');
    }
    
    const fechaFormateada = isNaN(fechaObj.getTime()) ? fecha : fechaObj.toLocaleDateString('es-ES', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric'
    });
    
    const mensaje = `BRASARGENT - Confirmación de Reserva\n\nHola ${nombre}!\n\nTu reserva en ${sucursal} está:\n- Fecha: ${fechaFormateada}\n- Hora: ${hora}\n\n¿Confirmas tu asistencia?\n¡Te esperamos!`;
    
    window.open(`https://wa.me/${telefono}?text=${encodeURIComponent(mensaje)}`, '_blank');
}

window.verDetalle = async function(id) {
    try {
        const response = await fetch(`/api/reservas/${id}`);
        const result = await response.json();
        
        if (!response.ok || !result.data) {
            alert(result.error || 'Error al obtener los detalles de la reserva.');
            return;
        }

        const reserva = result.data;
        
        const existente = document.getElementById('modalReservaIndividual');
        if (existente) existente.remove();

        const formatFecha = (f) => new Date(f).toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
        
        const modalHTML = `
            <div class="modal-overlay" id="modalReservaIndividual" onclick="window.cerrarModalDetalleIndividual()">
                <div class="modal-container" onclick="event.stopPropagation()">
                    <div class="modal-header">
                        <h2>Detalles de la Reserva</h2>
                        <button class="modal-close" onclick="window.cerrarModalDetalleIndividual()">✕</button>
                    </div>
                    <div class="modal-body">
                        <div class="detalle-grid">
                            <div class="detalle-item">
                                <span class="detalle-label">Cliente</span>
                                <span class="detalle-valor"><strong>${reserva.nombre_cliente}</strong></span>
                            </div>
                            <div class="detalle-item">
                                <span class="detalle-label">Teléfono</span>
                                <span class="detalle-valor"> ${reserva.codigo_pais || '591'} ${reserva.telefono}</span>
                            </div>
                            <div class="detalle-item">
                                <span class="detalle-label">Sucursal</span>
                                <span class="detalle-valor"> ${reserva.sucursal || 'Desconocida'}</span>
                            </div>
                            <div class="detalle-item">
                                <span class="detalle-label">Fecha y Hora</span>
                                <span class="detalle-valor"> ${formatFecha(reserva.fecha)} a las  ${reserva.hora}</span>
                            </div>
                            <div class="detalle-item">
                                <span class="detalle-label">Personas</span>
                                <span class="detalle-valor"> ${reserva.numero_personas} personas</span>
                            </div>
                            <div class="detalle-item">
                                <span class="detalle-label">Estado</span>
                                <span class="detalle-valor"> ${reserva.estado.toUpperCase()}</span>
                            </div>
                        </div>
                        
                        <div class="observaciones-box">
                            <span class="detalle-label">Mensaje / Observaciones del comensal:</span>
                            <div class="mensaje-texto">
                                ${reserva.observaciones ? reserva.observaciones : '<em>El cliente no dejó ningún mensaje u observación.</em>'}
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-cancel" onclick="window.cerrarModalDetalleIndividual()">Cerrar</button>
                    </div>
                </div>
            </div>
        `;
        
        document.body.insertAdjacentHTML('beforeend', modalHTML);
        document.body.classList.add('modal-open');
        
    } catch (error) {
        console.error('Error fetching reservation details:', error);
        alert('Error de conexión al obtener detalles.');
    }
}

window.cerrarModalDetalleIndividual = function() {
    const modal = document.getElementById('modalReservaIndividual');
    if (modal) {
        modal.style.opacity = '0';
        setTimeout(() => {
            modal.remove();
            document.body.classList.remove('modal-open');
        }, 300);
    }
}

window.borrarReserva = async function(id) {
    if (confirm(`¿Estás seguro de que deseas eliminar esta reserva?\n\nEsta acción no se puede deshacer.`)) {
        try {
            const response = await fetch(`/api/reservas/${id}`, {
                method: 'DELETE'
            });
            const result = await response.json();
            
            if (result.success) {
                location.reload();
            } else {
                alert(result.error || 'Hubo un error al eliminar la reserva.');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Error de conexión al intentar eliminar.');
        }
    }
}
</script>

<style is:global>
