</style>

<script define:vars={{ id }}>
// ============================================
// MANEJO DE HORARIOS
// ============================================

// Agregar bloque de horario
function agregarBloque(btn) {
    const diaContainer = btn.closest('.horario-dia');
    const bloquesContainer = diaContainer.querySelector('.dia-bloques');
    
    const nuevoBloque = document.createElement('div');
    nuevoBloque.className = 'bloque-horario';
    nuevoBloque.innerHTML = `
        <div class="bloque-inputs">
            <div class="bloque-item">
                <label>Inicio</label>
                <input type="time" class="bloque-inicio" value="18:30" />
            </div>
            <div class="bloque-item">
                <label>Fin</label>
                <input type="time" class="bloque-fin" value="22:00" />
            </div>
        </div>
        <button type="button" class="btn-eliminar-bloque" onclick="eliminarBloque(this)">✕</button>
    `;
    
    bloquesContainer.appendChild(nuevoBloque);
}

// Eliminar bloque de horario
function eliminarBloque(btn) {
    const bloque = btn.closest('.bloque-horario');
    const diaContainer = bloque.closest('.horario-dia');
    const bloques = diaContainer.querySelectorAll('.bloque-horario');
    
    if (bloques.length <= 1) {
        alert('Debe haber al menos un bloque de horario por día');
        return;
    }
    
    if (confirm('¿Eliminar este bloque de horario?')) {
        bloque.remove();
    }
}

// Toggle día activo/inactivo
function toggleDia(checkbox) {
    const diaContainer = checkbox.closest('.horario-dia');
    const bloques = diaContainer.querySelectorAll('.bloque-horario input');
    const btnAgregar = diaContainer.querySelector('.btn-agregar-bloque');
    
    if (checkbox.checked) {
        bloques.forEach(input => input.disabled = false);
        btnAgregar.disabled = false;
    } else {
        bloques.forEach(input => input.disabled = true);
        btnAgregar.disabled = true;
    }
}

// ============================================
// ENVÍO DEL FORMULARIO
// ============================================
document.getElementById('formEditarSucursal').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const btn = document.getElementById('btnGuardar');
    btn.textContent = '⏳ Guardando...';
    btn.disabled = true;
    
    // Recolectar datos del formulario
    const nombre = document.getElementById('nombre').value.trim();
    const concepto = document.getElementById('concepto').value;
    const direccion = document.getElementById('direccion').value.trim();
    const telefono = document.getElementById('telefono').value.trim();
    const capacidad = parseInt(document.getElementById('capacidad').value) || 120;
    const rating = parseFloat(document.getElementById('rating').value) || 4.5;
    const activo = document.getElementById('activo').checked;
    const permiteReservas = document.getElementById('permiteReservas').checked;
    const permiteCubiertos = document.getElementById('permiteCubiertos').checked;
    
    // Validaciones
    if (!nombre) {
        alert('❌ El nombre de la sucursal es obligatorio');
        btn.textContent = '💾 Guardar Cambios';
        btn.disabled = false;
        return;
    }
    
    if (!direccion) {
        alert('❌ La dirección es obligatoria');
        btn.textContent = '💾 Guardar Cambios';
        btn.disabled = false;
        return;
    }
    
    if (!telefono) {
        alert('❌ El teléfono es obligatorio');
        btn.textContent = '💾 Guardar Cambios';
        btn.disabled = false;
        return;
    }
    
    // Recolectar horarios
    const horarios = {};
    const dias = document.querySelectorAll('.horario-dia');
    
    dias.forEach(dia => {
        const diaId = dia.dataset.dia;
        const diaActivo = dia.querySelector('.dia-activo').checked;
        const bloques = [];
        const bloqueElements = dia.querySelectorAll('.bloque-horario');
        
        bloqueElements.forEach(bloque => {
            const inicio = bloque.querySelector('.bloque-inicio').value;
            const fin = bloque.querySelector('.bloque-fin').value;
            if (inicio && fin) {
                bloques.push({ inicio, fin });
            }
        });
        
        horarios[diaId] = {
            activo: diaActivo,
            bloques: bloques
        };
    });
    
    // Preparar datos
    const data = {
        id: id,
        nombre,
        concepto,
        direccion,
        telefono,
        capacidad_total: capacidad,
        rating,
        activo: activo ? 1 : 0,
        permite_reservas: permiteReservas ? 1 : 0,
        permite_cubiertos: permiteCubiertos ? 1 : 0,
        horarios: horarios
    };
    
    try {
        const response = await fetch('/api/sucursales/editar', {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            alert('✅ Sucursal actualizada exitosamente');
            window.location.href = '/admin/sucursales';
        } else {
            alert('❌ Error: ' + result.error);
            btn.textContent = '💾 Guardar Cambios';
            btn.disabled = false;
        }
    } catch (error) {
        alert('❌ Error de conexión. Intenta de nuevo.');
        btn.textContent = '💾 Guardar Cambios';
        btn.disabled = false;
    }
});

// Adjuntar handlers a window para que los eventos inline los encuentren en módulos de Astro
window.agregarBloque = agregarBloque;
window.eliminarBloque = eliminarBloque;
window.toggleDia = toggleDia;
</script>
