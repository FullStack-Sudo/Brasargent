---
// src/pages/admin/sucursales/editar/[id].astro
// Edición completa de sucursal

import AdminLayout from '../../../../layouts/AdminLayout.astro';
import pool from '../../../../lib/db';

// Obtener ID de la sucursal
const { id } = Astro.params;

// Obtener datos de la sucursal
const [rows] = await pool.query(
    `SELECT 
        s.*,
        (SELECT COUNT(*) FROM pedidos_cocina_grupo WHERE sucursal_id = s.id AND estado != 'entregado') AS pedidos_activos
     FROM sucursales s 
     WHERE s.id = ?`,
    [id]
) as any[];

const sucursal = rows[0];

// Si no existe, redirigir
if (!sucursal) {
    return Astro.redirect('/admin/sucursales');
}

// Obtener estadísticas de reservas para cubiertos
const [statsRows] = await pool.query(
    `SELECT 
        COALESCE(SUM(numero_personas), 0) AS ocupados_actuales
     FROM reservas 
     WHERE sucursal_id = ? 
     AND fecha = CURDATE() 
     AND estado = 'confirmada'`,
    [id]
) as any[];

const stats = statsRows[0];

// Calcular cubiertos
const capacidad_total = sucursal.capacidad_total || 120;
const cubiertos_ocupados = stats?.ocupados_actuales || 0;
const cubiertos_disponibles = capacidad_total - cubiertos_ocupados;

// Parsear horarios
let horarios: any = {};
try {
    horarios = typeof sucursal.horarios === 'string' 
        ? JSON.parse(sucursal.horarios) 
        : sucursal.horarios || {};
} catch {
    horarios = {};
}

// Días de la semana
const diasSemana = [
    { id: 'lunes', label: 'Lunes' },
    { id: 'martes', label: 'Martes' },
    { id: 'miercoles', label: 'Miércoles' },
    { id: 'jueves', label: 'Jueves' },
    { id: 'viernes', label: 'Viernes' },
    { id: 'sabado', label: 'Sábado' },
    { id: 'domingo', label: 'Domingo' }
];

// Conceptos disponibles
const conceptos = [
    { value: 'Churrasquería', label: '🔥 Churrasquería' },
    { value: 'Rodizio Tradicional', label: '🥩 Rodizio Tradicional' },
    { value: 'Restaurante', label: '🍽️ Restaurante' },
    { value: 'Fast Grill', label: '⚡ Fast Grill' },
    { value: 'Parrilla', label: '🔥 Parrilla' }
];

// Formatear horario para mostrar
const formatearHorario = (horarioStr: any) => {
    if (!horarioStr) return 'Cerrado';
    const bloques = typeof horarioStr === 'string' ? JSON.parse(horarioStr) : horarioStr;
    if (!bloques || bloques.length === 0) return 'Cerrado';
    return bloques.map((b: any) => `${b.inicio} - ${b.fin}`).join(' / ');
};
---

<AdminLayout title={`Editar ${sucursal.nombre}`} description="Modifica los datos de la sucursal">
    <div class="editar-sucursal">
        <!-- Header -->
        <div class="page-header">
            <div>
                <h1>✏️ Editar {sucursal.nombre}</h1>
                <p>Modifica los datos, horarios y capacidad de la sucursal</p>
            </div>
            <a href="/admin/sucursales" class="btn-volver">← Volver a Sucursales</a>
        </div>

        <!-- Información de Cubiertos -->
        <div class="cubiertos-resumen">
            <div class="cubiertos-item total">
                <span class="cubiertos-icon">🪑</span>
                <div>
                    <span class="cubiertos-numero">{capacidad_total}</span>
                    <span class="cubiertos-label">Capacidad Total</span>
                </div>
            </div>
            <div class="cubiertos-item ocupados">
                <span class="cubiertos-icon">🔴</span>
                <div>
                    <span class="cubiertos-numero">{cubiertos_ocupados}</span>
                    <span class="cubiertos-label">Ocupados (hoy)</span>
                </div>
            </div>
            <div class="cubiertos-item disponibles">
                <span class="cubiertos-icon">🟢</span>
                <div>
                    <span class="cubiertos-numero">{cubiertos_disponibles}</span>
                    <span class="cubiertos-label">Disponibles (hoy)</span>
                </div>
            </div>
        </div>

        <!-- Formulario -->
        <form id="formEditarSucursal" class="form-sucursal">
            <!-- Información General -->
            <div class="form-section">
                <h3>📋 Información General</h3>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>Nombre de la Sucursal *</label>
                        <input 
                            type="text" 
                            id="nombre" 
                            value={sucursal.nombre}
                            placeholder="Ej: Churrasquería"
                            required
                        />
                    </div>
                    <div class="form-group">
                        <label>Concepto *</label>
                        <select id="concepto" required>
                            {conceptos.map(c => (
                                <option value={c.value} selected={c.value === sucursal.concepto}>
                                    {c.label}
                                </option>
                            ))}
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Dirección *</label>
                    <input 
                        type="text" 
                        id="direccion" 
                        value={sucursal.direccion}
                        placeholder="Ej: Sucursal Beni, Av. casi - 5to anillo"
                        required
                    />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Teléfono *</label>
                        <input 
                            type="tel" 
                            id="telefono" 
                            value={sucursal.telefono}
                            placeholder="Ej: 70000001"
                            required
                        />
                    </div>
                    <div class="form-group">
                        <label>Capacidad Total (Cubiertos)</label>
                        <input 
                            type="number" 
                            id="capacidad" 
                            value={sucursal.capacidad_total || 120}
                            min="1"
                            max="500"
                        />
                        <span class="field-hint">Número total de cubiertos disponibles</span>
                    </div>
                </div>

                <div class="form-group">
                    <label>Rating (Opcional)</label>
                    <input 
                        type="number" 
                        id="rating" 
                        value={sucursal.rating || 4.5}
                        step="0.1"
                        min="0"
                        max="5"
                    />
                </div>

                <div class="form-group checkbox-group">
                    <label class="checkbox-label">
                        <input type="checkbox" id="activo" checked={sucursal.activo === 1} />
                        <span class="custom-checkbox"></span>
                        <div>
                            <strong>Sucursal Activa</strong>
                            <small>Si está inactiva, no aparecerá en la página pública</small>
                        </div>
                    </label>
                </div>

                <div class="form-row">
                    <div class="form-group checkbox-group">
                        <label class="checkbox-label">
                            <input type="checkbox" id="permiteReservas" checked={sucursal.permite_reservas === 1} />
                            <span class="custom-checkbox"></span>
                            <div>
                                <strong>📅 Permite Reservas</strong>
                                <small>Si está activo, los clientes pueden reservar en esta sucursal</small>
                            </div>
                        </label>
                    </div>
                    
                    <div class="form-group checkbox-group">
                        <label class="checkbox-label">
                            <input type="checkbox" id="permiteCubiertos" checked={sucursal.permite_cubiertos === 1} />
                            <span class="custom-checkbox"></span>
                            <div>
                                <strong>🪑 Permite Cubiertos</strong>
                                <small>Si está activo, muestra disponibilidad de cubiertos</small>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <!-- Horarios de Atención -->
            <div class="form-section">
                <h3>🕐 Horarios de Atención</h3>
                <p class="section-desc">Configura los horarios para cada día de la semana</p>

                <div class="horarios-container">
                    {diasSemana.map((dia) => {
                        const horarioDia = horarios[dia.id] || { activo: true, bloques: [{ inicio: '11:30', fin: '15:00' }] };
                        const bloques = horarioDia.bloques || [{ inicio: '11:30', fin: '15:00' }];
                        
                        return (
                            <div class="horario-dia" data-dia={dia.id}>
                                <div class="dia-header">
                                    <div class="dia-info">
                                        <span class="dia-nombre">{dia.label}</span>
                                    </div>
                                    <div class="dia-controls">
                                        <label class="switch-small">
                                            <input 
                                                type="checkbox" 
                                                class="dia-activo" 
                                                checked={horarioDia.activo !== false}
                                                onchange="toggleDia(this)"
                                            />
                                            <span class="slider-small"></span>
                                        </label>
                                        <button type="button" class="btn-agregar-bloque" onclick="agregarBloque(this)">
                                            ➕ Agregar Horario
                                        </button>
                                    </div>
                                </div>
                                <div class="dia-bloques">
                                    {bloques.map((bloque: any, index: number) => (
                                        <div class="bloque-horario" data-index={index}>
                                            <div class="bloque-inputs">
                                                <div class="bloque-item">
                                                    <label>Inicio</label>
                                                    <input 
                                                        type="time" 
                                                        class="bloque-inicio" 
                                                        value={bloque.inicio || '11:30'}
                                                    />
                                                </div>
                                                <div class="bloque-item">
                                                    <label>Fin</label>
                                                    <input 
                                                        type="time" 
                                                        class="bloque-fin" 
                                                        value={bloque.fin || '15:00'}
                                                    />
                                                </div>
                                            </div>
                                            <button type="button" class="btn-eliminar-bloque" onclick="eliminarBloque(this)">
                                                ✕
                                            </button>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        );
                    })}
                </div>
            </div>

            <!-- Botones de Acción -->
            <div class="form-actions">
                <a href="/admin/sucursales" class="btn-cancelar">Cancelar</a>
                <button type="submit" class="btn-guardar" id="btnGuardar">
                    💾 Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</AdminLayout>

<style is:global>
/* ============================================
   EDICIÓN DE SUCURSAL - ESTILOS
   ============================================ */
.editar-sucursal {
