    transition: all 0.3s ease;
}

.slider-small::before {
    content: '';
    position: absolute;
    height: 14px;
    width: 14px;
    left: 3px;
    bottom: 3px;
    background: white;
    border-radius: 50%;
    transition: all 0.3s ease;
}

.switch-small input:checked + .slider-small {
    background: #10b981;
}

.switch-small input:checked + .slider-small::before {
