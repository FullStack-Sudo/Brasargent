---
// src/pages/admin/sucursales/index.astro
// Gestión de sucursales y cubiertos

import AdminLayout from '../../../layouts/AdminLayout.astro';
import pool from '../../../lib/db';

// Obtener todas las sucursales
const sucursalesData = await pool.query(`
    SELECT 
        s.id,
        s.nombre,
        s.concepto,
        s.direccion,
        s.horario,
        s.telefono,
        s.capacidad,
        s.capacidad_total,
        s.cubiertos_disponibles,
        s.cubiertos_ocupados,
        s.activo,
        COUNT(DISTINCT ms.plato_id) AS total_platos
    FROM sucursales s
    LEFT JOIN menu_sucursal ms ON s.id = ms.sucursal_id
    WHERE s.activo = 1
    GROUP BY s.id
    ORDER BY s.nombre
`) as any[];

const sucursales = sucursalesData[0] || [];
---

<AdminLayout title="Sucursales" description="Controla la capacidad y cubiertos de cada local">
    <div class="sucursales-grid">
        {sucursales.map((sucursal: any) => {
            const color = sucursal.nombre === 'Churrasquería' ? '#9e2a2b' :
                         sucursal.nombre === 'Fast Grill' ? '#d4af37' : '#d4a574';
            const icono = sucursal.nombre === 'Churrasquería' ? '🔥' :
                         sucursal.nombre === 'Fast Grill' ? '⚡' : '🥩';
            
            const porcentaje = sucursal.cubiertos_ocupados > 0 
                ? Math.round((sucursal.cubiertos_ocupados / sucursal.capacidad_total) * 100) 
                : 0;
            
            return (
                <div class="sucursal-card" style={`border-top: 4px solid ${color}`}>
                    <div class="sucursal-header">
                        <div class="sucursal-info">
                            <span class="sucursal-icon" style={`color: ${color}`}>{icono}</span>
                            <div>
                                <h3>{sucursal.nombre}</h3>
                                <span class="sucursal-concepto">{sucursal.concepto || 'Restaurante'}</span>
                            </div>
                        </div>
                        <span class="sucursal-estado">
                            {sucursal.activo ? '✅ Activo' : '❌ Inactivo'}
                        </span>
                    </div>
                    
                    <div class="sucursal-detalles">
                        <p>📍 {sucursal.direccion}</p>
                        <p>🕐 {sucursal.horario}</p>
                        <p>📞 <a href={`https://wa.me/${sucursal.telefono}`} target="_blank">{sucursal.telefono}</a></p>
                    </div>
                    
                    <!-- Control de Cubiertos -->
                    <div class="cubiertos-control">
                        <div class="cubiertos-header">
                            <span>🪑 Cubiertos</span>
                            <div class="cubiertos-numeros">
                                <span class="cubiertos-total">Total: {sucursal.capacidad_total || 120}</span>
                                <span class="cubiertos-ocupados">Ocupados: {sucursal.cubiertos_ocupados || 0}</span>
                                <span class="cubiertos-disponibles">Disponibles: {sucursal.cubiertos_disponibles || 120}</span>
                            </div>
                        </div>
                        <div class="cubiertos-bar">
                            <div class="cubiertos-progreso" style={`width: ${porcentaje}%; background: ${porcentaje > 80 ? '#ef4444' : porcentaje > 60 ? '#f59e0b' : '#10b981'}`}></div>
                        </div>
                        <div class="cubiertos-porcentaje">
                            <span>{porcentaje}% ocupado</span>
                            <span class="cubiertos-libres">{sucursal.cubiertos_disponibles} cubiertos libres</span>
                        </div>
                    </div>
                    
                    <div class="sucursal-actions">
                        <a href={`/admin/sucursales/editar/${sucursal.id}`} class="btn-editar-capacidad">
                            ✏️ Editar Capacidad
                        </a>
                        <a href={`/admin/sucursales/cubiertos/${sucursal.id}`} class="btn-ajustar">
                            ⚙️ Ajustar Cubiertos
                        </a>
                    </div>
                </div>
            );
        })}
    </div>
</AdminLayout>

<style is:global>
/* ============================================
   ESTILOS DE SUCURSALES
   ============================================ */
.sucursales-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 24px;
    margin-top: 24px;
}

.sucursal-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
}

.sucursal-card:hover {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
}

.sucursal-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
}

.sucursal-info {
    display: flex;
    align-items: center;
    gap: 12px;
}

.sucursal-icon {
    font-size: 2rem;
}

.sucursal-info h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
}

.sucursal-concepto {
    font-size: 0.75rem;
    color: rgba(26, 26, 26, 0.4);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.sucursal-estado {
    font-size: 0.85rem;
    font-weight: 500;
}

.sucursal-detalles {
    background: rgba(255, 250, 240, 0.5);
    border-radius: 10px;
    padding: 12px 16px;
    margin: 12px 0 16px;
}

.sucursal-detalles p {
    margin: 4px 0;
    font-size: 0.85rem;
    color: #1a1a1a;
}

.sucursal-detalles a {
    color: #25d366;
    text-decoration: none;
}

.cubiertos-control {
    background: rgba(255, 250, 240, 0.5);
    border-radius: 10px;
    padding: 14px 16px;
    margin: 12px 0 16px;
}

.cubiertos-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.cubiertos-header span {
    font-weight: 600;
    font-size: 0.9rem;
    color: #1a1a1a;
}

.cubiertos-numeros {
    display: flex;
    gap: 12px;
    font-size: 0.75rem;
    font-weight: 500;
}

.cubiertos-total { color: #3b82f6; }
.cubiertos-ocupados { color: #ef4444; }
.cubiertos-disponibles { color: #10b981; }

.cubiertos-bar {
    width: 100%;
    height: 6px;
    background: rgba(26, 26, 26, 0.06);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 6px;
}

.cubiertos-progreso {
    height: 100%;
    border-radius: 3px;
    transition: width 0.8s ease;
}

.cubiertos-porcentaje {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: rgba(26, 26, 26, 0.4);
}

.cubiertos-libres {
    font-weight: 500;
}

.sucursal-actions {
    display: flex;
    gap: 10px;
}

.btn-editar-capacidad,
.btn-ajustar {
    flex: 1;
    padding: 10px 16px;
    border: none;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
}

.btn-editar-capacidad {
    background: rgba(59, 130, 246, 0.08);
    color: #3b82f6;
}

.btn-editar-capacidad:hover {
    background: rgba(59, 130, 246, 0.15);
    transform: scale(1.02);
}

.btn-ajustar {
    background: rgba(158, 42, 43, 0.08);
    color: #9e2a2b;
}

.btn-ajustar:hover {
    background: rgba(158, 42, 43, 0.15);
    transform: scale(1.02);
}

@media (max-width: 768px) {
    .sucursales-grid {
        grid-template-columns: 1fr;
    }
}
</style>
