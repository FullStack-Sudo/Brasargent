    document.body.insertAdjacentHTML('beforeend', modalHTML);
    document.body.classList.add('modal-open');
    
    // Cargar turnos (estáticos en UI local) cuando cambie la fecha
    document.getElementById('fechaReserva').addEventListener('change', function() {
        window._cargarTurnosModal(sucursalId, this.value);
    });
    
    // Cargar turnos inmediatamente
    window._cargarTurnosModal(sucursalId, fechaActual);
    
    document.getElementById('formReservaCliente').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const turnoInput = document.getElementById('turnoReserva');
        const horaInput = document.getElementById('horaReserva');
        const turnoSeleccionado = turnoInput?.value;
        const horaSeleccionada = horaInput?.value;

        if (!turnoSeleccionado) {
            alert('❌ Por favor selecciona un turno (Mañana/Tarde/Noche)');
            return;
        }
        
        if (!horaSeleccionada) {
            alert('❌ Por favor selecciona una hora disponible');
            return;
        }
        
        const btn = document.getElementById('btnEnviarReserva');
        btn.classList.add('loading');
        btn.disabled = true;
        
        const data = {
            sucursal_id: sucursalId,
            nombre_cliente: document.getElementById('nombreCliente').value.trim(),
            telefono: document.getElementById('telefonoCliente').value.trim(),
            codigo_pais: document.getElementById('codigoPais').value,
            fecha: document.getElementById('fechaReserva').value,
            turno: turnoSeleccionado,
            hora: horaSeleccionada,
            numero_personas: parseInt(document.getElementById('personasReserva').value),
            observaciones: document.getElementById('observacionesReserva').value.trim()
        };
        
        try {
            const response = await fetch('/api/reservas/cliente', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await response.json();
            
            if (result.success) {
                alert('✅ Reserva solicitada con éxito. Te confirmaremos por WhatsApp.');
                cerrarModalReserva();
            } else {
                alert('❌ Error: ' + result.error);
                btn.classList.remove('loading');
                btn.disabled = false;
            }
        } catch (err) {
            alert('❌ Error de red');
            btn.classList.remove('loading');
            btn.disabled = false;
        }
    });
}

function cerrarModalReserva() {
    const modal = document.getElementById('modalReservaCliente');
    if (modal) {
        modal.style.opacity = '0';
        setTimeout(() => modal.remove(), 300);
    }
    document.body.classList.remove('modal-open');
}

window.abrirModalReserva = abrirModalReserva;
window.cerrarModalReserva = cerrarModalReserva;
window.seleccionarHora = seleccionarHora;
</script>
