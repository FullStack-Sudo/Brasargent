                                <option value="52">🇲🇽 +52 (México)</option>
                            </select>
                            <input type="tel" id="telefonoCliente" placeholder="70000111" required />
                        </div>
                    </div>
                    
                    <!-- Fecha -->
                    <div class="form-group">
                        <label>📅 Fecha <span class="required">*</span></label>
                        <input type="date" id="fechaReserva" min="${fechaActual}" value="${fechaActual}" required />
                    </div>
                    
                    <!-- Selector de Turno y Hora (UI Original Estática) -->
                    <div class="form-group" id="grupoTurnoHora">
                        <div id="turnosContainer" class="turnos-container">
                            <label class="field-label">
                                Turno
                                <span class="required">*</span>
                            </label>
                            <div id="turnosGrid" class="turnos-grid"></div>
                            <span class="error-message" id="errorTurno" style="display: none; color: #ef4444; font-size: 0.8rem; margin-top: 4px;">Por favor selecciona un turno</span>

                            <div id="horasWrapper" class="horas-wrapper hidden">
                                <div id="horasContainer" class="reloj-digital-wrapper">
                                    <div class="reloj-digital-container">
                                        <select id="relojHora" class="reloj-select"></select>
                                        <span class="reloj-colon">:</span>
                                        <select id="relojMinuto" class="reloj-select"></select>
                                    </div>
                                    <div id="relojInfo" class="reloj-info" style="display: none;"></div>
                                </div>
                                <span class="error-message" id="errorHora" style="display: none; color: #ef4444; font-size: 0.8rem; margin-top: 4px;">Por favor selecciona una hora</span>
                            </div>
                        </div>

                        <input type="hidden" id="turnoReserva" />
