<script is:inline>
// ============================================
// 🔴 CARGAR TURNOS Y HORAS DESDE LA API
// ============================================

window._cargarTurnosModal = async function(sucursalId, fecha) {
    const loadingEl   = document.getElementById('turnosLoading');
    const errorEl     = document.getElementById('turnosError');
    const containerEl = document.getElementById('turnosContainer');
    const gridEl      = document.getElementById('turnosGrid');
    const horasWrap   = document.getElementById('horasWrapper');
    const horasEl     = document.getElementById('horasContainer');
    const fechaInput  = document.getElementById('fechaReserva');
    const turnoInput  = document.getElementById('turnoReserva');
    const horaInput   = document.getElementById('horaReserva');

    // Reset estado
    loadingEl.classList.remove('hidden');
    errorEl.classList.add('hidden');
    containerEl.classList.add('hidden');
    horasWrap.classList.add('hidden');
    gridEl.innerHTML = '';
    // ⚠️ NO destruir horasEl.innerHTML — contiene los <select> del reloj digital estático.
    // Solo limpiar las opciones de los selects y la info.
    const _relojH = document.getElementById('relojHora');
    const _relojM = document.getElementById('relojMinuto');
    const _relojI = document.getElementById('relojInfo');
    if (_relojH) _relojH.innerHTML = '';
    if (_relojM) _relojM.innerHTML = '';
    if (_relojI) _relojI.innerHTML = '';
    // Eliminar la capacidad dinámica si existe
    const _capOld = horasWrap?.querySelector('.capacidad-info');
    if (_capOld) _capOld.remove();
    turnoInput.value = '';
    horaInput.value = '';
    window._turnoData = null;

    try {
        const response = await fetch(`/api/reservas/horas-disponibles?sucursal_id=${sucursalId}&fecha=${fecha}`);
        const result = await response.json();
        
        loadingEl.classList.add('hidden');

        if (!result.success) {
            errorEl.innerHTML = `<span class="turnos-error-icon">⚠️</span><span>${result.error || 'Error al cargar disponibilidad'}</span>`;
            errorEl.classList.remove('hidden');
            return;
        }

        const data = result.data;

        // Validar y ajustar fecha mínima si el día de hoy ya venció/está cerrado
        if (data.proxima_fecha_disponible) {
            fechaInput.min = data.proxima_fecha_disponible;
            if (fechaInput.value < data.proxima_fecha_disponible) {
                fechaInput.value = data.proxima_fecha_disponible;
                // Cargar la nueva fecha disponible automáticamente
                window._cargarTurnosModal(sucursalId, data.proxima_fecha_disponible);
                return;
            }
        }

        // Verificar si permite reservas
        if (data.permite_reservas === false) {
            errorEl.innerHTML = '<span class="turnos-error-icon">🚫</span><span>Esta sucursal no acepta reservas en este momento</span>';
            errorEl.classList.remove('hidden');
            return;
        }
        
        // Verificar si está abierta/disponible
        if (!data.disponible && (!data.turnos || data.turnos.length === 0)) {
            errorEl.innerHTML = `<span class="turnos-error-icon">🗓️</span><span>${data.mensaje || 'La sucursal está cerrada este día'}</span>`;
            errorEl.classList.remove('hidden');
            return;
        }

        // Guardar datos en window
        window._turnoData = data;

        // Renderizar tarjetas de turno
        const iconos = { manana: '☀️', tarde: '🌅', noche: '🌙' };
        let html = '';
        data.turnos.forEach(turno => {
            const icono      = iconos[turno.tipo] || '⏰';
            const pct        = turno.disponibilidad;
            const estadoClase = pct === 0 ? 'turno-lleno' : pct < 30 ? 'turno-casi-lleno' : 'turno-disponible';
            const estadoLabel = pct === 0 ? 'Sin cupos' : pct < 30 ? 'Casi lleno' : 'Disponible';
            const disabled    = !turno.disponible ? 'disabled' : '';

            html += `
                <button
                    type="button"
                    class="turno-card ${!turno.disponible ? 'turno-card--disabled' : ''}"
                    data-turno-tipo="${turno.tipo}"
                    ${disabled}
                    onclick="window._seleccionarTurnoModal(this)"
                >
                    <span class="turno-icono">${icono}</span>
                    <div class="turno-info">
                        <span class="turno-nombre">${turno.label}</span>
                        <span class="turno-horario">${turno.inicio} – ${turno.fin}</span>
                    </div>
                    <div class="turno-badge ${estadoClase}">
                        <div class="turno-pct-bar"><div class="turno-pct-fill" style="width:${100 - pct}%"></div></div>
                        <span class="turno-badge-label">${estadoLabel}</span>
                    </div>
                </button>
            `;
        });

        gridEl.innerHTML = html;
        containerEl.classList.remove('hidden');
        
    } catch (error) {
        loadingEl.classList.add('hidden');
        errorEl.innerHTML = '<span class="turnos-error-icon">❌</span><span>Error de conexión. Intenta de nuevo.</span>';
        errorEl.classList.remove('hidden');
        console.error('Error cargando turnos:', error);
    }
}

// Alias para mantener compatibilidad
window.cargarHorasDisponibles = window._cargarTurnosModal;

// ============================================
// SELECCIONAR TURNO Y CARGAR RELOJ DIGITAL
// ============================================

window._seleccionarTurnoModal = function(element) {
    if (element.disabled || element.classList.contains('turno-card--disabled')) return;

    const gridEl      = document.getElementById('turnosGrid');
    const horasWrap   = document.getElementById('horasWrapper');
    const turnoInput  = document.getElementById('turnoReserva');
    const horaInput   = document.getElementById('horaReserva');
    
    const selectHora  = document.getElementById('relojHora');
    const selectMin   = document.getElementById('relojMinuto');
    const relojInfo   = document.getElementById('relojInfo');

    // Deseleccionar todos
    gridEl.querySelectorAll('.turno-card').forEach(c => c.classList.remove('turno-card--selected'));
    element.classList.add('turno-card--selected');

    const tipoTurno = element.dataset.turnoTipo;
    turnoInput.value = tipoTurno;

    // Ocultar error de turno
    const errorTurno = document.getElementById('errorTurno');
    if (errorTurno) errorTurno.style.display = 'none';

    // Limpiar hora seleccionada anterior
    horaInput.value = '';
    
    // Obtener horas del turno seleccionado
    const data = window._turnoData;
    if (!data) return;

    const turno = data.turnos.find(t => t.tipo === tipoTurno);
    if (!turno) return;

    // Extraer horas únicas (HH)
    const horasUnicas = [...new Set(turno.horas.map(h => h.hora.split(':')[0]))].sort();

    // Llenar select de horas
    selectHora.innerHTML = horasUnicas.map(h => `<option value="${h}">${h}</option>`).join('');

    // Función para actualizar minutos según la hora seleccionada
    function actualizarMinutos() {
        const horaSel = selectHora.value;
        const minutos = Array.from({length: 60}, (_, i) => String(i).padStart(2, '0'));

        selectMin.innerHTML = minutos.map(min => {
            return `<option value="${min}">${min}</option>`;
        }).join('');

        actualizarValorFinal();
    }

    // Función para actualizar el valor final de la hora y su cupo
    function actualizarValorFinal() {
        const horaSel = selectHora.value;
        const minSel = selectMin.value;
        if (!horaSel || !minSel) {
            horaInput.value = '';
            if (relojInfo) relojInfo.innerHTML = '';
            return;
        }

        const horaCompleta = `${horaSel}:${minSel}`;
        horaInput.value = horaCompleta;

        if (relojInfo) {
            relojInfo.innerHTML = '';
        }

        // Limpiar error de hora
        const errorHora = document.getElementById('errorHora');
        if (errorHora) errorHora.style.display = 'none';
    }

    // Bindear eventos
    selectHora.onchange = actualizarMinutos;
    selectMin.onchange = actualizarValorFinal;

    // Inicializar minutos e info
    actualizarMinutos();

    // Renderizar Info de capacidad general (fuera del grid de horas)
    let capInfo = horasWrap.querySelector('.capacidad-info');
    if (!capInfo) {
        capInfo = document.createElement('div');
        capInfo.className = 'capacidad-info';
        horasWrap.appendChild(capInfo);
    }
    capInfo.innerHTML = `
        <span class="info-disponibles">🪑 ${data.disponibles_hoy} cubiertos disponibles hoy</span>
        <span class="info-total">📋 Capacidad total: ${data.capacidad_total}</span>
    `;

    // Mostrar sección con animación
    horasWrap.classList.remove('hidden');
    horasWrap.classList.add('horas-animate-in');
    setTimeout(() => horasWrap.classList.remove('horas-animate-in'), 400);
}

// ============================================
// SELECCIONAR HORA (Mantenido por compatibilidad)
// ============================================

window._seleccionarHoraModal = function(element) {
    // Obsoleto por el Reloj Digital
}

window.seleccionarHora = window._seleccionarHoraModal;

// ============================================
// CAMBIAR CANTIDAD ADULTOS/NIÑOS/BEBÉS
// ============================================

window._cambiarCantidad = function(inputId, delta, min = 0, max = 10) {
    const input = document.getElementById(inputId);
    if (!input) return;
    let valor = parseInt(input.value) + delta;
    valor = Math.max(min, Math.min(max, valor));
    input.value = valor;
}

// ============================================
// ABRIR MODAL DE RESERVA (CON VALIDACIÓN)
// ============================================

function abrirModalReserva(sucursalId, sucursalNombre) {
    window._sucursalId = sucursalId;
    window._sucursalNombre = sucursalNombre;
    
    // Obtener fecha actual en Bolivia (en-CA garantiza formato YYYY-MM-DD sin bidi)
    const hoyBolivia = new Intl.DateTimeFormat('en-CA', {
        timeZone: 'America/La_Paz',
        year: 'numeric',
        month: '2-digit',
        day: '2-digit'
    }).format(new Date());
    
    abrirModalReservaUI(sucursalId, sucursalNombre, hoyBolivia);
}

// ============================================
// ABRIR MODAL UI
// ============================================

function abrirModalReservaUI(sucursalId, sucursalNombre, fechaActual) {
    const modalHTML = `
        <div class="modal-overlay" id="modalReservaCliente" onclick="cerrarModalReserva()">
