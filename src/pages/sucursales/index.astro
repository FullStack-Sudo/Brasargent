// src/pages/sucursales/index.astro
// Página pública de sucursales - RESPETA HORARIOS DEL ADMIN
import Layout from '../../layouts/Layout.astro';
import pool from '../../lib/db';

// Obtener sucursales activas con datos de cubiertos
const [rows] = await pool.query(`
    SELECT 
        id,
        nombre,
        concepto,
        rating,
        resenas,
        direccion,
        horarios,
        telefono,
        capacidad_total,
        COALESCE(cubiertos_disponibles, capacidad_total) AS cubiertos_disponibles,
        COALESCE(cubiertos_ocupados, 0) AS cubiertos_ocupados,
        permite_reservas,
        permite_cubiertos
    FROM sucursales
    WHERE activo = 1
    ORDER BY nombre
`) as any[];

const sucursales = rows || [];

// ============================================
// FUNCIONES DE VALIDACIÓN DE HORARIOS
// (Todas usan Intl.DateTimeFormat con tz Bolivia)
// ============================================

/** Día en formato clave: 'lunes', 'martes', ... 'miercoles' (sin tildes) */
function getDiaActual(): string {
    const dia = new Intl.DateTimeFormat('es-ES', {
        timeZone: 'America/La_Paz',
        weekday: 'long'
    }).format(new Date());
    // Quita tildes: miércoles → miercoles, sábado → sabado
    return dia.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
}

/** Hora actual en Bolivia en formato HH:mm (24h) */
function getHoraActualBolivia(): string {
    return new Intl.DateTimeFormat('en-US', {
        timeZone: 'America/La_Paz',
        hour: '2-digit',
        minute: '2-digit',
        hour12: false
    }).format(new Date());
}

/** ¿La sucursal tiene horario configurado y activo para hoy? */
function estaAbiertaHoy(horarios: any): boolean {
    try {
        const h = typeof horarios === 'string' ? JSON.parse(horarios) : horarios;
        const dia = getDiaActual();
        const hoy = h?.[dia];
        return !!(hoy?.activo && hoy?.bloques?.length > 0);
    } catch {
        return false;
    }
}

/** ¿La sucursal está ABIERTA en este momento según sus bloques horarios? */
function estaAbiertaAhora(horarios: any): boolean {
    try {
        const h = typeof horarios === 'string' ? JSON.parse(horarios) : horarios;
        const dia = getDiaActual();
        const hoy = h?.[dia];
        if (!hoy?.activo || !hoy?.bloques?.length) return false;
        const ahora = getHoraActualBolivia();
        return hoy.bloques.some((b: any) => ahora >= b.inicio && ahora <= b.fin);
    } catch {
        return false;
    }
}

/** Texto del horario de hoy para mostrar en la card */
function getHorarioHoy(horarios: any): string {
    try {
        const h = typeof horarios === 'string' ? JSON.parse(horarios) : horarios;
        const dia = getDiaActual();
        const hoy = h?.[dia];
        if (!hoy?.activo || !hoy?.bloques?.length) return '🔴 Cerrado hoy';
        const bloques = hoy.bloques.map((b: any) => `${b.inicio} - ${b.fin}`).join(' / ');
        return `🟢 ${bloques}`;
    } catch {
        return '⚠️ Horario no disponible';
    }
}

/** HTML con el horario de todos los días */
function getHorarioCompleto(horarios: any): string {
    if (!horarios) return 'Horario no disponible';
    try {
        const h = typeof horarios === 'string' ? JSON.parse(horarios) : horarios;
        const dias  = ['lunes','martes','miercoles','jueves','viernes','sabado','domingo'];
        const nombres = ['Lunes','Martes','Miércoles','Jueves','Viernes','Sábado','Domingo'];
        const hoy = getDiaActual();
        return dias.map((dia, i) => {
            const horario = h?.[dia];
            const esHoy = dia === hoy;
            const clase = esHoy ? (horario?.activo ? 'dia-hoy' : 'dia-hoy cerrado') : '';
            if (horario?.activo && horario?.bloques?.length > 0) {
                const bloques = horario.bloques.map((b: any) => `${b.inicio} - ${b.fin}`).join(' / ');
                return `<span class="${clase}">${nombres[i]}: ${bloques}</span>`;
            }
            return `<span class="${clase}">${nombres[i]}: 🔴 Cerrado</span>`;
        }).join(' | ');
    } catch {
        return 'Horario no disponible';
    }
}
---

<Layout title="Sucursales - BRASARGENT">
    <div class="sucursales-page">
        <div class="sucursales-header">
            <h1>📍 Nuestras Sucursales</h1>
            <p>Encuentra la sucursal más cercana y reserva tu mesa</p>
        </div>
        
        <div class="sucursales-grid">
            {sucursales.map((sucursal: any) => {
                const icono = sucursal.nombre === 'Churrasquería' ? '🔥' :
                             sucursal.nombre === 'Fast Grill' ? '⚡' : '🥩';
                const color = sucursal.nombre === 'Churrasquería' ? '#9e2a2b' :
                             sucursal.nombre === 'Fast Grill' ? '#d4af37' : '#d4a574';
                
                // ============================================
                // 🔴 VALIDACIÓN COMPLETA DE 7 PASOS
                // ============================================

                // PASO 1: ¿Permite reservas según BD?
                const permiteReservas = sucursal.permite_reservas === 1;

                // PASO 2: ¿Hay horarios configurados?
                const tieneHorarios = !!sucursal.horarios;

                // PASO 3: ¿Está abierta hoy (tiene bloques activos para este día)?
                const abiertoHoy = estaAbiertaHoy(sucursal.horarios);

                // PASO 4: ¿Está abierta AHORA (hora actual dentro de un bloque)?
                const abiertoAhora = estaAbiertaAhora(sucursal.horarios);

                // PASO 5: ¿Hay cubiertos disponibles?
                const cubiertos = Number(sucursal.cubiertos_disponibles ?? sucursal.capacidad_total ?? 0);
                const hayCubiertos = cubiertos > 0;

                // DECISIÓN FINAL: mostrar botón activo solo si todo está OK
                const puedeReservar = permiteReservas && tieneHorarios && abiertoHoy && abiertoAhora && hayCubiertos;

                // Razón clara para mostrar en botón deshabilitado
                let razonDeshabilitado = '';
                if (!permiteReservas)         razonDeshabilitado = '🚫 No acepta reservas';
                else if (!tieneHorarios)      razonDeshabilitado = '⚠️ Horario no disponible';
                else if (!abiertoHoy)         razonDeshabilitado = '🔴 Cerrado hoy';
                else if (!abiertoAhora)       razonDeshabilitado = '🔴 Cerrado ahora';
                else if (!hayCubiertos)       razonDeshabilitado = '🪑 Sin disponibilidad';

                // Horario de hoy en texto
                const horarioHoy = getHorarioHoy(sucursal.horarios);
                
                return (
                    <div class="sucursal-card" style={`border-top: 4px solid ${color}`}>
                        <div class="sucursal-header">
                            <div class="sucursal-info">
                                <span class="sucursal-icon" style={`color: ${color}`}>{icono}</span>
                                <div>
                                    <h3>{sucursal.nombre}</h3>
                                    <span class="sucursal-concepto">{sucursal.concepto || 'Restaurante'}</span>
                                </div>
                            </div>
                            <div class="sucursal-rating">
                                ★ {sucursal.rating || 4.5} <span>({sucursal.resenas || 0} reseñas)</span>
                            </div>
                        </div>
                        
                        <div class="sucursal-detalles">
                            <p>📍 {sucursal.direccion}</p>
                            
                            <!-- HORARIO DE HOY -->
                            <div class="horario-hoy">
                                <span class="horario-label">🕐 Hoy</span>
                                <span class={`horario-estado ${abiertoAhora ? 'abierto' : 'cerrado'}`}>
                                    {horarioHoy}
                                </span>
                            </div>
                            
                            <!-- HORARIO COMPLETO (acordeón) -->
                            <details class="horario-completo">
                                <summary>📋 Ver horario completo</summary>
                                <div class="horario-detalle">
                                    <span set:html={getHorarioCompleto(sucursal.horarios)}></span>
                                </div>
                            </details>
                            
                            <p>📞 <a href={`https://wa.me/${sucursal.telefono}`} target="_blank">{sucursal.telefono}</a></p>
                            <p>🪑 Capacidad: {sucursal.capacidad_total || 120} cubiertos</p>
                            
                            {sucursal.permite_cubiertos === 1 && (
                                <span class="badge-cubiertos">✅ Cubiertos disponibles</span>
                            )}

                            {!permiteReservas && (
                                <span class="badge-no-reservas">🚫 No acepta reservas</span>
                            )}
                        </div>
                        
                        <div class="sucursal-actions">
                            <a href="#" class="btn-ubicacion">📍 Ubicación</a>
                            <a href="#" class="btn-menu">🍽️ Menú</a>
                            <a href={`https://wa.me/${sucursal.telefono}`} target="_blank" class="btn-whatsapp">💬 WhatsApp</a>
                            
                            {/* 🔴 BOTÓN RESERVAR — 7 validaciones requeridas */}
                            {puedeReservar ? (
                                <button
                                    class="btn-reservar"
                                    onclick={`window.abrirModalPublico(${sucursal.id})`}
                                    title="Reservar mesa"
                                >
                                    📅 Reservar
                                </button>
                            ) : (
                                <button
                                    class="btn-reservar-disabled"
                                    disabled
                                    title={razonDeshabilitado}
                                >
                                    {razonDeshabilitado || '🚫 No disponible'}
                                </button>
                            )}
                        </div>
                    </div>
                );
            })}
        </div>
    </div>
</Layout>

<style>
