                    </div>
                    
                    <div class="form-group personas-section">
                        <label>👥 Número de Adultos *</label>
                        <div class="cantidad-wrapper">
                            <button type="button" class="btn-cantidad btn-menos" onclick="window._cambiarCantidad('personasReserva', -1, 1, 20)">−</button>
                            <input type="number" id="personasReserva" value="2" min="1" max="20" oninput="this.value = Math.max(1, Math.min(20, parseInt(this.value) || 2))" required />
                            <button type="button" class="btn-cantidad btn-mas" onclick="window._cambiarCantidad('personasReserva', 1, 1, 20)">+</button>
                            <span class="cantidad-label">adultos</span>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label>📝 Comentarios <span class="optional">(Opcional)</span></label>
                        <textarea id="observacionesReserva" rows="2" placeholder="Ej: Prefiero mesa cerca de la ventana"></textarea>
                    </div>
                </form>
                
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" onclick="cerrarModalReserva()">Cancelar</button>
                    <button type="submit" class="btn-save" id="btnEnviarReserva" form="formReservaCliente">
                        <span class="btn-text">📅 Solicitar Reserva</span>
